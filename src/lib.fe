msg ERC721ExcubiaMsg {
    #[selector = 0x53000001]
    SetGate { gate: Address } -> u256,
    #[selector = 0x53000002]
    Check { passerby: Address, token_id: u256 } -> u256,
    #[selector = 0x53000003]
    Pass { passerby: Address, token_id: u256 } -> u256,
    #[selector = 0x53000004]
    Gate -> u256,
    #[selector = 0x53000005]
    Trait -> u256,
    #[selector = 0x53000006]
    HasPassedTokenId { token_id: u256 } -> bool,
}

struct ERC721ExcubiaStore {
    owner: Address,
    gate: Address,
    nft: Address,
    passed_token_ids: StorageMap<u256, bool>,
}

pub contract ERC721Excubia uses (ctx: Ctx, call: mut Call, log: mut Log) {
    mut store: ERC721ExcubiaStore

    init(nft: Address) uses (mut store, ctx) {
        assert(nft != Address::zero())
        store.owner = ctx.caller()
        store.gate = Address::zero()
        store.nft = nft
    }

    recv ERC721ExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(store.owner, store.gate, ctx.caller(), gate)
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check { passerby, token_id } -> u256 uses (store, mut call) {
            let owner_inner: u256 = call.call(
                addr: store.nft,
                gas: 100000,
                value: 0,
                message: MockERC721Msg::OwnerOf { token_id: token_id },
            )
            if owner_inner != passerby.inner {
                return ExcubiaError::UnexpectedTokenOwner.code()
            }
            ExcubiaError::None.code()
        }

        Pass { passerby, token_id } -> u256 uses (mut store, ctx, mut call, mut log) {
            let err = excubia_gate_only_err(store.gate, ctx.caller())
            if !err.is_none() {
                return err.code()
            }
            if store.passed_token_ids.get(key: token_id) {
                return ExcubiaError::AlreadyPassed.code()
            }

            let owner_inner: u256 = call.call(
                addr: store.nft,
                gas: 100000,
                value: 0,
                message: MockERC721Msg::OwnerOf { token_id: token_id },
            )
            if owner_inner != passerby.inner {
                return ExcubiaError::UnexpectedTokenOwner.code()
            }

            store.passed_token_ids.set(key: token_id, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_ERC721
        }

        HasPassedTokenId { token_id } -> bool uses (store) {
            store.passed_token_ids.get(key: token_id)
        }
    }
}

