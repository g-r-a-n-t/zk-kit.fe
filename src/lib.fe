const EXCUBIA_HAT_LIMIT: usize = 4
const GITCOIN_SCORE_FACTOR: u256 = 100
const EAS_SCHEMA_ID: u256 = 0xfdcfdad2dbe7489e0ce56b260348b7f14e8365a8a325aef9834818c00d46b31b

enum ExcubiaError {
    None,
    OwnerOnly,
    ZeroAddress,
    GateOnly,
    GateAlreadySet,
    AlreadyPassed,
    UnexpectedTokenOwner,
    InsufficientScore,
    NotWearingCriterionHat,
    NotCriterionHat,
    UnexpectedSchema,
    UnexpectedAttester,
    UnexpectedRecipient,
    RevokedAttestation,
    InvalidGroup,
    InvalidProof,
    UnexpectedScope,
    InvalidEventId,
    InvalidSigners,
    InvalidWatermark,
}

impl ExcubiaError {
    pub fn is_none(self) -> bool {
        match self {
            ExcubiaError::None => true,
            _ => false,
        }
    }

    pub fn code(self) -> u256 {
        match self {
            ExcubiaError::None => 0,
            ExcubiaError::OwnerOnly => 1,
            ExcubiaError::ZeroAddress => 2,
            ExcubiaError::GateOnly => 3,
            ExcubiaError::GateAlreadySet => 4,
            ExcubiaError::AlreadyPassed => 5,
            ExcubiaError::UnexpectedTokenOwner => 6,
            ExcubiaError::InsufficientScore => 7,
            ExcubiaError::NotWearingCriterionHat => 8,
            ExcubiaError::NotCriterionHat => 9,
            ExcubiaError::UnexpectedSchema => 10,
            ExcubiaError::UnexpectedAttester => 11,
            ExcubiaError::UnexpectedRecipient => 12,
            ExcubiaError::RevokedAttestation => 13,
            ExcubiaError::InvalidGroup => 14,
            ExcubiaError::InvalidProof => 15,
            ExcubiaError::UnexpectedScope => 16,
            ExcubiaError::InvalidEventId => 17,
            ExcubiaError::InvalidSigners => 18,
            ExcubiaError::InvalidWatermark => 19,
        }
    }
}

#[event]
struct GateSetEvent {
    #[indexed]
    gate: Address,
}

#[event]
struct GatePassedEvent {
    #[indexed]
    passerby: Address,
    #[indexed]
    gate: Address,
}

fn excubia_set_gate_err(owner: Address, gate: Address, caller: Address, new_gate: Address) -> ExcubiaError {
    if caller != owner {
        return ExcubiaError::OwnerOnly
    }
    if new_gate == Address::zero() {
        return ExcubiaError::ZeroAddress
    }
    if gate != Address::zero() {
        return ExcubiaError::GateAlreadySet
    }
    ExcubiaError::None
}

fn excubia_gate_only_err(gate: Address, caller: Address) -> ExcubiaError {
    if caller != gate {
        return ExcubiaError::GateOnly
    }
    ExcubiaError::None
}

fn emit_gate_set(gate: Address) uses (log: mut Log) {
    log.emit(GateSetEvent { gate })
}

fn emit_gate_passed(passerby: Address, gate: Address) uses (log: mut Log) {
    log.emit(GatePassedEvent { passerby, gate })
}

fn eas_attestation_err(
    eas: Address,
    attestation_id: u256,
    schema: u256,
    attester: Address,
    passerby: Address,
) -> ExcubiaError uses (call: mut Call) {
    let actual_schema: u256 = call.call(
        addr: eas,
        gas: 100000,
        value: 0,
        message: MockEASMsg::GetSchema { uid: attestation_id },
    )
    if actual_schema != schema {
        return ExcubiaError::UnexpectedSchema
    }

    let actual_attester: u256 = call.call(
        addr: eas,
        gas: 100000,
        value: 0,
        message: MockEASMsg::GetAttester { uid: attestation_id },
    )
    if actual_attester != attester.inner {
        return ExcubiaError::UnexpectedAttester
    }

    let actual_recipient: u256 = call.call(
        addr: eas,
        gas: 100000,
        value: 0,
        message: MockEASMsg::GetRecipient { uid: attestation_id },
    )
    if actual_recipient != passerby.inner {
        return ExcubiaError::UnexpectedRecipient
    }

    let revocation_time: u256 = call.call(
        addr: eas,
        gas: 100000,
        value: 0,
        message: MockEASMsg::GetRevocationTime { uid: attestation_id },
    )
    if revocation_time != 0 {
        return ExcubiaError::RevokedAttestation
    }

    ExcubiaError::None
}

fn semaphore_proof_err(
    semaphore: Address,
    group_id: u256,
    scope: u256,
    nullifier: u256,
) -> ExcubiaError uses (call: mut Call) {
    if scope != group_id {
        return ExcubiaError::UnexpectedScope
    }

    let is_valid: bool = call.call(
        addr: semaphore,
        gas: 100000,
        value: 0,
        message: MockSemaphoreMsg::VerifyProof { group_id: group_id, nullifier: nullifier },
    )
    if !is_valid {
        return ExcubiaError::InvalidProof
    }

    ExcubiaError::None
}

fn zkeddsa_ecmul(x: u256, y: u256, scalar: u256) -> (bool, u256, u256) {
    let input_ptr = mem::alloc(96)
    mstore(input_ptr, x)
    mstore(input_ptr + 32, y)
    mstore(input_ptr + 64, scalar)

    let output_ptr = mem::alloc(64)
    let ok = staticcall(
        gas: 1000000,
        addr: 7,
        args_offset: input_ptr,
        args_len: 96,
        ret_offset: output_ptr,
        ret_len: 64,
    )
    (ok == 1, mload(output_ptr), mload(output_ptr + 32))
}

fn zkeddsa_ecadd(x0: u256, y0: u256, x1: u256, y1: u256) -> (bool, u256, u256) {
    let input_ptr = mem::alloc(128)
    mstore(input_ptr, x0)
    mstore(input_ptr + 32, y0)
    mstore(input_ptr + 64, x1)
    mstore(input_ptr + 96, y1)

    let output_ptr = mem::alloc(64)
    let ok = staticcall(
        gas: 1000000,
        addr: 6,
        args_offset: input_ptr,
        args_len: 128,
        ret_offset: output_ptr,
        ret_len: 64,
    )
    (ok == 1, mload(output_ptr), mload(output_ptr + 32))
}

fn zkeddsa_g1_mul_acc(acc: [u256; 2], point: [u256; 2], scalar: u256) -> (bool, [u256; 2]) {
    let (mul_ok, mul_x, mul_y) = zkeddsa_ecmul(point[0], point[1], scalar)
    if !mul_ok {
        return (false, [0, 0])
    }

    let (add_ok, add_x, add_y) = zkeddsa_ecadd(acc[0], acc[1], mul_x, mul_y)
    if !add_ok {
        return (false, [0, 0])
    }

    (true, [add_x, add_y])
}

fn zkeddsa_verify_pairing(
    p_a: [u256; 2],
    p_b: [[u256; 2]; 2],
    p_c: [u256; 2],
    vk_x: [u256; 2],
) -> bool {
    let pairing_ptr = mem::alloc(768)
    mstore(pairing_ptr, p_a[0])
    mstore(pairing_ptr + 32, mulmod(p_a[1], ZKEDDSA_Q - 1, ZKEDDSA_Q))
    mstore(pairing_ptr + 64, p_b[0][0])
    mstore(pairing_ptr + 96, p_b[0][1])
    mstore(pairing_ptr + 128, p_b[1][0])
    mstore(pairing_ptr + 160, p_b[1][1])
    mstore(pairing_ptr + 192, ZKEDDSA_ALPHAX)
    mstore(pairing_ptr + 224, ZKEDDSA_ALPHAY)
    mstore(pairing_ptr + 256, ZKEDDSA_BETAX1)
    mstore(pairing_ptr + 288, ZKEDDSA_BETAX2)
    mstore(pairing_ptr + 320, ZKEDDSA_BETAY1)
    mstore(pairing_ptr + 352, ZKEDDSA_BETAY2)
    mstore(pairing_ptr + 384, vk_x[0])
    mstore(pairing_ptr + 416, vk_x[1])
    mstore(pairing_ptr + 448, ZKEDDSA_GAMMAX1)
    mstore(pairing_ptr + 480, ZKEDDSA_GAMMAX2)
    mstore(pairing_ptr + 512, ZKEDDSA_GAMMAY1)
    mstore(pairing_ptr + 544, ZKEDDSA_GAMMAY2)
    mstore(pairing_ptr + 576, p_c[0])
    mstore(pairing_ptr + 608, p_c[1])
    mstore(pairing_ptr + 640, ZKEDDSA_DELTAX1)
    mstore(pairing_ptr + 672, ZKEDDSA_DELTAX2)
    mstore(pairing_ptr + 704, ZKEDDSA_DELTAY1)
    mstore(pairing_ptr + 736, ZKEDDSA_DELTAY2)

    let output_ptr = mem::alloc(32)
    let ok = staticcall(
        gas: 1000000,
        addr: 8,
        args_offset: pairing_ptr,
        args_len: 768,
        ret_offset: output_ptr,
        ret_len: 32,
    )
    ok == 1 && mload(output_ptr) != 0
}

fn zkeddsa_proof_err(
    verifier: Address,
    valid_event_id: u256,
    valid_signer_0: u256,
    valid_signer_1: u256,
    passerby: Address,
    p_a: [u256; 2],
    p_b: [[u256; 2]; 2],
    p_c: [u256; 2],
    pub_signals: [u256; 38],
) -> ExcubiaError uses (call: mut Call) {
    if pub_signals[13] != valid_signer_0 || pub_signals[14] != valid_signer_1 {
        return ExcubiaError::InvalidSigners
    }
    if pub_signals[15] != valid_event_id {
        return ExcubiaError::InvalidEventId
    }
    if pub_signals[37] != passerby.inner {
        return ExcubiaError::InvalidWatermark
    }

    let is_valid: bool = call.static(
        addr: verifier,
        gas: 2000000,
        message: ZKEdDSAEventTicketPCDVerifierMsg::VerifyProof {
            p_a: p_a,
            p_b: p_b,
            p_c: p_c,
            pub_signals: pub_signals,
        },
    )
    if !is_valid {
        return ExcubiaError::InvalidProof
    }

    ExcubiaError::None
}


msg FreeForAllExcubiaMsg {
    #[selector = 0x51000001]
    SetGate { gate: Address } -> u256,
    #[selector = 0x51000002]
    Check { passerby: Address } -> u256,
    #[selector = 0x51000003]
    Pass { passerby: Address } -> u256,
    #[selector = 0x51000004]
    Gate -> u256,
    #[selector = 0x51000005]
    Trait -> u256,
    #[selector = 0x51000006]
    HasPassed { passerby: Address } -> bool,
}

struct FreeForAllExcubiaStore {
    owner: Address,
    gate: Address,
    passed_passersby: StorageMap<Address, bool>,
}

pub contract FreeForAllExcubia uses (ctx: Ctx, log: mut Log) {
    mut store: FreeForAllExcubiaStore

    init() uses (mut store, ctx) {
        store.owner = ctx.caller()
        store.gate = Address::zero()
    }

    recv FreeForAllExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(store.owner, store.gate, ctx.caller(), gate)
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check { passerby } -> u256 {
            let _ = passerby
            ExcubiaError::None.code()
        }

        Pass { passerby } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_gate_only_err(store.gate, ctx.caller())
            if !err.is_none() {
                return err.code()
            }
            if store.passed_passersby.get(key: passerby) {
                return ExcubiaError::AlreadyPassed.code()
            }

            store.passed_passersby.set(key: passerby, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_FREE_FOR_ALL
        }

        HasPassed { passerby } -> bool uses (store) {
            store.passed_passersby.get(key: passerby)
        }
    }
}

