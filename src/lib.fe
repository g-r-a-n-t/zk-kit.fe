const LEAN_MAP_CAPACITY: usize = 256
const LEAN_MAP_CAPACITY_U256: u256 = 256
const LEAN_BATCH_MAX: usize = 64

pub enum LeanIMTError {
    None,
    WrongSiblingNodes,
    LeafGreaterThanSnarkScalarField,
    LeafCannotBeZero,
    LeafAlreadyExists,
    LeafDoesNotExist,
    DepthNotSupported,
    SparseMapFull,
}

impl LeanIMTError {
    pub fn is_none(self) -> bool {
        match self {
            LeanIMTError::None => true,
            _ => false,
        }
    }
    pub fn code(self) -> u256 {
        match self {
            LeanIMTError::None => 0,
            LeanIMTError::WrongSiblingNodes => 1,
            LeanIMTError::LeafGreaterThanSnarkScalarField => 2,
            LeanIMTError::LeafCannotBeZero => 3,
            LeanIMTError::LeafAlreadyExists => 4,
            LeanIMTError::LeafDoesNotExist => 5,
            LeanIMTError::DepthNotSupported => 6,
            LeanIMTError::SparseMapFull => 7,
        }
    }
}

pub struct LeanIMTData {
    pub size: usize,
    pub depth: usize,
    pub side_nodes: [u256; MAX_DEPTH_PLUS_ONE],
    pub leaf_used: [u8; LEAN_MAP_CAPACITY],
    pub leaf_keys: [u256; LEAN_MAP_CAPACITY],
    pub leaf_values: [u256; LEAN_MAP_CAPACITY],
}

impl LeanIMTData {
    pub fn empty() -> Self {
        LeanIMTData {
            size: 0,
            depth: 0,
            side_nodes: [0; MAX_DEPTH_PLUS_ONE],
            leaf_used: [0; LEAN_MAP_CAPACITY],
            leaf_keys: [0; LEAN_MAP_CAPACITY],
            leaf_values: [0; LEAN_MAP_CAPACITY],
        }
    }

    fn leaf_get_value(self, leaf: u256) -> (bool, u256) {
        let mut slot = (leaf % LEAN_MAP_CAPACITY_U256) as usize
        let mut i: usize = 0

        while i < LEAN_MAP_CAPACITY {
            if self.leaf_used[slot] == 0 {
                return (false, 0)
            }

            if self.leaf_keys[slot] == leaf {
                if self.leaf_values[slot] == 0 {
                    return (false, 0)
                }
                return (true, self.leaf_values[slot])
            }

            slot += 1
            if slot == LEAN_MAP_CAPACITY {
                slot = 0
            }
            i += 1
        }

        (false, 0)
    }

    fn leaf_set_value(mut self, leaf: u256, value: u256) -> LeanIMTError {
        let mut slot = (leaf % LEAN_MAP_CAPACITY_U256) as usize
        let mut first_tombstone: usize = LEAN_MAP_CAPACITY
        let mut i: usize = 0

        while i < LEAN_MAP_CAPACITY {
            if self.leaf_used[slot] == 0 {
                if first_tombstone != LEAN_MAP_CAPACITY {
                    slot = first_tombstone
                }
                self.leaf_used[slot] = 1
                self.leaf_keys[slot] = leaf
                self.leaf_values[slot] = value
                return LeanIMTError::None
            }

            if self.leaf_keys[slot] == leaf {
                self.leaf_values[slot] = value
                return LeanIMTError::None
            }

            if self.leaf_values[slot] == 0 && first_tombstone == LEAN_MAP_CAPACITY {
                first_tombstone = slot
            }

            slot += 1
            if slot == LEAN_MAP_CAPACITY {
                slot = 0
            }
            i += 1
        }

        if first_tombstone != LEAN_MAP_CAPACITY {
            self.leaf_used[first_tombstone] = 1
            self.leaf_keys[first_tombstone] = leaf
            self.leaf_values[first_tombstone] = value
            return LeanIMTError::None
        }

        LeanIMTError::SparseMapFull
    }

    fn leaf_delete(mut self, leaf: u256) {
        let mut slot = (leaf % LEAN_MAP_CAPACITY_U256) as usize
        let mut i: usize = 0

        while i < LEAN_MAP_CAPACITY {
            if self.leaf_used[slot] == 0 {
                return
            }

            if self.leaf_keys[slot] == leaf {
                self.leaf_values[slot] = 0
                return
            }

            slot += 1
            if slot == LEAN_MAP_CAPACITY {
                slot = 0
            }
            i += 1
        }
    }
    pub fn has(self, leaf: u256) -> bool {
        let (ok, _value) = self.leaf_get_value(leaf)
        ok
    }
    pub fn index_of(self, leaf: u256) -> (usize, LeanIMTError) {
        let (ok, value) = self.leaf_get_value(leaf)
        if !ok {
            return (0, LeanIMTError::LeafDoesNotExist)
        }

        ((value - 1) as usize, LeanIMTError::None)
    }
    pub fn root(self) -> u256 {
        self.side_nodes[self.depth]
    }
    pub fn insert(mut self, leaf: u256) -> (u256, LeanIMTError) {
        if leaf >= SNARK_SCALAR_FIELD {
            return (0, LeanIMTError::LeafGreaterThanSnarkScalarField)
        }
        if leaf == 0 {
            return (0, LeanIMTError::LeafCannotBeZero)
        }
        if self.has(leaf) {
            return (0, LeanIMTError::LeafAlreadyExists)
        }

        let mut index = self.size
        let mut tree_depth = self.depth

        if tree_depth > MAX_DEPTH {
            return (0, LeanIMTError::DepthNotSupported)
        }

        if (1 << tree_depth) < index + 1 {
            tree_depth += 1
        }
        if tree_depth > MAX_DEPTH {
            return (0, LeanIMTError::DepthNotSupported)
        }

        self.depth = tree_depth
        let mut node = leaf

        let mut level: usize = 0
        while level < tree_depth {
            if ((index >> level) & 1) == 1 {
                node = hash2(self.side_nodes[level], node)
            } else {
                self.side_nodes[level] = node
            }

            level += 1
        }

        index += 1
        self.size = index
        self.side_nodes[tree_depth] = node
        let err = self.leaf_set_value(leaf, index as u256)
        if !err.is_none() {
            return (0, err)
        }

        (node, LeanIMTError::None)
    }
    pub fn insert_many(mut self, leaves: [u256; LEAN_BATCH_MAX], count: usize) -> (
        u256,
        LeanIMTError,
    ) {
        if count > LEAN_BATCH_MAX {
            return (0, LeanIMTError::DepthNotSupported)
        }

        let mut i: usize = 0
        while i < count {
            let leaf = leaves[i]
            if leaf >= SNARK_SCALAR_FIELD {
                return (0, LeanIMTError::LeafGreaterThanSnarkScalarField)
            }
            if leaf == 0 {
                return (0, LeanIMTError::LeafCannotBeZero)
            }
            if self.has(leaf) {
                return (0, LeanIMTError::LeafAlreadyExists)
            }

            let mut j: usize = 0
            while j < i {
                if leaves[j] == leaf {
                    return (0, LeanIMTError::LeafAlreadyExists)
                }
                j += 1
            }

            i += 1
        }

        let mut root = self.root()
        i = 0
        while i < count {
            let (new_root, err) = self.insert(leaves[i])
            if !err.is_none() {
                return (0, err)
            }
            root = new_root
            i += 1
        }

        (root, LeanIMTError::None)
    }
    pub fn update(
        mut self,
        old_leaf: u256,
        new_leaf: u256,
        siblings: [u256; MAX_DEPTH],
        sibling_count: usize,
    ) -> (u256, LeanIMTError) {
        if new_leaf >= SNARK_SCALAR_FIELD {
            return (0, LeanIMTError::LeafGreaterThanSnarkScalarField)
        }
        let (old_exists, old_leaf_value) = self.leaf_get_value(old_leaf)
        if !old_exists {
            return (0, LeanIMTError::LeafDoesNotExist)
        }
        let (new_exists, _new_leaf_value) = self.leaf_get_value(new_leaf)
        if new_leaf != 0 && new_exists {
            return (0, LeanIMTError::LeafAlreadyExists)
        }

        let index = (old_leaf_value - 1) as usize

        let mut node = new_leaf
        let mut old_root = old_leaf
        let last_index = self.size - 1
        let tree_depth = self.depth
        let mut i: usize = 0
        let mut level: usize = 0

        while level < tree_depth {
            if ((index >> level) & 1) == 1 {
                if i >= sibling_count || siblings[i] >= SNARK_SCALAR_FIELD {
                    return (0, LeanIMTError::LeafGreaterThanSnarkScalarField)
                }

                node = hash2(siblings[i], node)
                old_root = hash2(siblings[i], old_root)
                i += 1
            } else {
                if (index >> level) != (last_index >> level) {
                    if i >= sibling_count || siblings[i] >= SNARK_SCALAR_FIELD {
                        return (0, LeanIMTError::LeafGreaterThanSnarkScalarField)
                    }

                    if self.side_nodes[level] == old_root {
                        self.side_nodes[level] = node
                    }

                    node = hash2(node, siblings[i])
                    old_root = hash2(old_root, siblings[i])
                    i += 1
                } else {
                    self.side_nodes[level] = node
                }
            }

            level += 1
        }

        if old_root != self.side_nodes[self.depth] {
            return (0, LeanIMTError::WrongSiblingNodes)
        }

        self.side_nodes[tree_depth] = node

        if new_leaf != 0 {
            let (ok, value) = self.leaf_get_value(old_leaf)
            if !ok {
                return (0, LeanIMTError::LeafDoesNotExist)
            }
            let err = self.leaf_set_value(new_leaf, value)
            if !err.is_none() {
                return (0, err)
            }
        }

        self.leaf_delete(old_leaf)
        (node, LeanIMTError::None)
    }
    pub fn remove(mut self, old_leaf: u256, siblings: [u256; MAX_DEPTH], sibling_count: usize) -> (
        u256,
        LeanIMTError,
    ) {
        self.update(old_leaf, 0, siblings, sibling_count)
    }
}

#[test]
fn test_lean_insert_has_index_and_root() {
    let mut tree = LeanIMTData::empty()

    let (_root, err) = tree.insert(1)
    assert(err.code() == LeanIMTError::None.code())
    assert(tree.has(1))
    assert(!tree.has(2))

    let (idx, err) = tree.index_of(1)
    assert(err.code() == LeanIMTError::None.code())
    assert(idx == 0)

    let (_root, err) = tree.insert(2)
    assert(err.code() == LeanIMTError::None.code())
    assert(tree.root() == hash2(1, 2))
}

#[test]
fn test_lean_insert_many_update_remove_roundtrip() {
    let mut tree = LeanIMTData::empty()
    let mut batch: [u256; LEAN_BATCH_MAX] = [0; LEAN_BATCH_MAX]
    batch[0] = 1
    batch[1] = 2
    batch[2] = 3

    let (_root, err) = tree.insert_many(batch, 3)
    assert(err.code() == LeanIMTError::None.code())
    assert(tree.root() == hash2(hash2(1, 2), 3))

    let mut siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    siblings[0] = 1
    siblings[1] = 3
    let (_root, err) = tree.update(2, 9, siblings, 2)
    assert(err.code() == LeanIMTError::None.code())
    assert(tree.root() == hash2(hash2(1, 9), 3))

    let mut remove_siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    remove_siblings[0] = hash2(1, 9)
    let (_root, err) = tree.remove(3, remove_siblings, 1)
    assert(err.code() == LeanIMTError::None.code())
    assert(tree.root() == hash2(hash2(1, 9), 0))

    assert(!tree.has(3))
}

#[test]
fn test_lean_insert_many_error_cases() {
    let mut too_many: [u256; LEAN_BATCH_MAX] = [0; LEAN_BATCH_MAX]
    let mut tree = LeanIMTData::empty()

    let (_root, err) = tree.insert_many(too_many, LEAN_BATCH_MAX + 1)
    assert(err.code() == LeanIMTError::DepthNotSupported.code())

    let mut invalid_leaf: [u256; LEAN_BATCH_MAX] = [0; LEAN_BATCH_MAX]
    invalid_leaf[0] = SNARK_SCALAR_FIELD
    let (_root, err) = tree.insert_many(invalid_leaf, 1)
    assert(
        err.code() == LeanIMTError::LeafGreaterThanSnarkScalarField.code(),
    )

    let mut zero_leaf: [u256; LEAN_BATCH_MAX] = [0; LEAN_BATCH_MAX]
    zero_leaf[0] = 0
    let (_root, err) = tree.insert_many(zero_leaf, 1)
    assert(err.code() == LeanIMTError::LeafCannotBeZero.code())

    let mut duplicate_batch: [u256; LEAN_BATCH_MAX] = [0; LEAN_BATCH_MAX]
    duplicate_batch[0] = 7
    duplicate_batch[1] = 7
    let (_root, err) = tree.insert_many(duplicate_batch, 2)
    assert(err.code() == LeanIMTError::LeafAlreadyExists.code())

    let (_root, err) = tree.insert(1)
    assert(err.code() == LeanIMTError::None.code())

    let mut duplicate_existing: [u256; LEAN_BATCH_MAX] = [0; LEAN_BATCH_MAX]
    duplicate_existing[0] = 1
    let (_root, err) = tree.insert_many(duplicate_existing, 1)
    assert(err.code() == LeanIMTError::LeafAlreadyExists.code())
}

#[test]
fn test_lean_insert_many_when_tree_is_not_empty() {
    let mut tree = LeanIMTData::empty()

    let (_root, err) = tree.insert(1)
    assert(err.code() == LeanIMTError::None.code())

    let mut batch: [u256; LEAN_BATCH_MAX] = [0; LEAN_BATCH_MAX]
    batch[0] = 2
    batch[1] = 3
    batch[2] = 4

    let (_root, err) = tree.insert_many(batch, 3)
    assert(err.code() == LeanIMTError::None.code())
    assert(tree.root() == hash2(hash2(1, 2), hash2(3, 4)))
    assert(tree.has(1))
    assert(tree.has(2))
    assert(tree.has(3))
    assert(tree.has(4))
}

#[test]
fn test_lean_update_rejects_existing_and_removed_leaves() {
    let mut tree = LeanIMTData::empty()
    let mut batch: [u256; LEAN_BATCH_MAX] = [0; LEAN_BATCH_MAX]
    batch[0] = 1
    batch[1] = 2

    let (_root, err) = tree.insert_many(batch, 2)
    assert(err.code() == LeanIMTError::None.code())

    let mut siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    siblings[0] = 2

    let (_root, err) = tree.update(1, 2, siblings, 1)
    assert(err.code() == LeanIMTError::LeafAlreadyExists.code())

    let mut remove_siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    remove_siblings[0] = 1
    let (_root, err) = tree.remove(2, remove_siblings, 1)
    assert(err.code() == LeanIMTError::None.code())

    let (_root, err) = tree.update(2, 3, siblings, 1)
    assert(err.code() == LeanIMTError::LeafDoesNotExist.code())
}

#[test]
fn test_lean_error_cases() {
    let mut tree = LeanIMTData::empty()
    let (_root, err) = tree.insert(0)
    assert(err.code() == LeanIMTError::LeafCannotBeZero.code())
    let (_root, err) = tree.insert(SNARK_SCALAR_FIELD)
    assert(
        err.code() == LeanIMTError::LeafGreaterThanSnarkScalarField.code(),
    )

    let (_root, err) = tree.insert(1)
    assert(err.code() == LeanIMTError::None.code())
    let (_root, err) = tree.insert(2)
    assert(err.code() == LeanIMTError::None.code())
    let (_root, err) = tree.insert(1)
    assert(err.code() == LeanIMTError::LeafAlreadyExists.code())

    let mut wrong_siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    wrong_siblings[0] = 3
    let (_root, err) = tree.update(1, 7, wrong_siblings, 1)
    assert(err.code() == LeanIMTError::WrongSiblingNodes.code())

    let (_idx, err) = tree.index_of(99)
    assert(err.code() == LeanIMTError::LeafDoesNotExist.code())
}

const LAZY_TOWER_HEIGHT: usize = 24
const LAZY_TOWER_WIDTH: u256 = 4
const LAZY_TOWER_BITS_PER_LEVEL: usize = 4
const LAZY_TOWER_LEVEL_BITMASK: u256 = 15
const LAZY_TOWER_ONES: u256 = 0x111111111111111111111111

pub enum LazyTowerError {
    None,
    ItemMustBeInField,
}

impl LazyTowerError {
    pub fn is_none(self) -> bool {
        match self {
            LazyTowerError::None => true,
            _ => false,
        }
    }
    pub fn code(self) -> u256 {
        match self {
            LazyTowerError::None => 0,
            LazyTowerError::ItemMustBeInField => 1,
        }
    }
}

pub struct LazyTowerHashChainData {
    pub level_lengths: u256,
    pub digests: [u256; LAZY_TOWER_HEIGHT],
    pub digest_of_digests: [u256; LAZY_TOWER_HEIGHT],
    level_counts: [usize; LAZY_TOWER_HEIGHT],
    level_items: [u256; LAZY_TOWER_HEIGHT * 4],
}

impl LazyTowerHashChainData {
    pub fn empty() -> Self {
        LazyTowerHashChainData {
            level_lengths: 0,
            digests: [0; LAZY_TOWER_HEIGHT],
            digest_of_digests: [0; LAZY_TOWER_HEIGHT],
            level_counts: [0; LAZY_TOWER_HEIGHT],
            level_items: [0; LAZY_TOWER_HEIGHT * 4],
        }
    }

    fn find_lowest_non_full_level_then_inc(level_lengths: u256) -> (usize, bool, bool, u256) {
        let mut level: usize = 0
        let mut shifted = level_lengths
        let mut level_length = shifted & LAZY_TOWER_LEVEL_BITMASK

        while level_length >= LAZY_TOWER_WIDTH {
            level += 1
            shifted = shifted >> (LAZY_TOWER_BITS_PER_LEVEL as u256)
            level_length = shifted & LAZY_TOWER_LEVEL_BITMASK
        }

        let is_head = level_length == 0
        let is_top = (shifted >> (LAZY_TOWER_BITS_PER_LEVEL as u256)) == 0

        let full_level_bits = level * LAZY_TOWER_BITS_PER_LEVEL
        let mut ones_mask: u256 = 0
        if full_level_bits > 0 {
            ones_mask = ((1 as u256) << (full_level_bits as u256)) - 1
        }

        let new_level_lengths = ((shifted + 1) << (full_level_bits as u256))
            + (ones_mask & LAZY_TOWER_ONES)
        (level, is_head, is_top, new_level_lengths)
    }
    pub fn add(mut self, item: u256) -> LazyTowerError {
        if item >= SNARK_SCALAR_FIELD {
            return LazyTowerError::ItemMustBeInField
        }

        let (_, _, _, new_level_lengths) = LazyTowerHashChainData::find_lowest_non_full_level_then_inc(self.level_lengths)
        let mut carry = item
        let mut level: usize = 0

        while true {
            let len = self.level_counts[level]
            if len < 4 {
                self.level_items[level * 4 + len] = carry
                self.level_counts[level] = len + 1
                let current = [
                    self.level_items[level * 4],
                    self.level_items[level * 4 + 1],
                    self.level_items[level * 4 + 2],
                    self.level_items[level * 4 + 3],
                ]
                self.digests[level] = hash_chain4(current, self.level_counts[level])
                break
            }

            let current = [
                self.level_items[level * 4],
                self.level_items[level * 4 + 1],
                self.level_items[level * 4 + 2],
                self.level_items[level * 4 + 3],
            ]
            let incoming = carry
            carry = hash_chain4(current, 4)

            self.level_items[level * 4] = incoming
            self.level_items[level * 4 + 1] = 0
            self.level_items[level * 4 + 2] = 0
            self.level_items[level * 4 + 3] = 0
            self.level_counts[level] = 1
            self.digests[level] = incoming
            level += 1
        }

        self.digest_of_digests = [0; LAZY_TOWER_HEIGHT]
        self.level_lengths = new_level_lengths

        let mut height: usize = 0
        let mut scan: usize = LAZY_TOWER_HEIGHT
        while scan != 0 {
            scan -= 1
            if self.level_counts[scan] != 0 {
                height = scan + 1
                break
            }
        }

        if height != 0 {
            let mut level = height - 1
            self.digest_of_digests[level] = self.digests[level]
            while level != 0 {
                level -= 1
                self.digest_of_digests[level] = hash2(
                    self.digest_of_digests[level + 1],
                    self.digests[level],
                )
            }
        }

        LazyTowerError::None
    }
    pub fn get_data_for_proving(self) -> (u256, [u256; LAZY_TOWER_HEIGHT], u256) {
        let mut digests: [u256; LAZY_TOWER_HEIGHT] = [0; LAZY_TOWER_HEIGHT]
        let mut i: usize = 0
        while i < LAZY_TOWER_HEIGHT {
            digests[i] = self.digests[i]
            i += 1
        }

        (self.level_lengths, digests, self.digest_of_digests[0])
    }
}

fn lazytower_after_150() -> LazyTowerHashChainData {
    let mut tower = LazyTowerHashChainData::empty()
    let mut i: usize = 0
    while i < 150 {
        let err = tower.add(i as u256)
        assert(err.code() == LazyTowerError::None.code())
        i += 1
    }

    tower
}

fn hash_chain4(levels: [u256; 4], len: usize) -> u256 {
    if len == 0 {
        return 0
    }
    if len == 1 {
        return levels[0]
    }

    let mut acc = hash2(levels[0], levels[1])
    let mut i: usize = 2
    while i < len {
        acc = hash2(acc, levels[i])
        i += 1
    }

    acc
}

fn lazytower_shift_tower_after_150() -> (u256, [u256; LAZY_TOWER_HEIGHT], u256) {
    let mut lengths = [0; LAZY_TOWER_HEIGHT]
    let mut levels = [0; LAZY_TOWER_HEIGHT * 4]
    let mut i: usize = 0

    while i < 150 {
        let mut carry = i as u256
        let mut level: usize = 0

        while true {
            let len = lengths[level]
            if len < 4 {
                levels[level * 4 + len] = carry
                lengths[level] = len + 1
                break
            }

            let current = [
                levels[level * 4],
                levels[level * 4 + 1],
                levels[level * 4 + 2],
                levels[level * 4 + 3],
            ]
            let incoming = carry
            carry = hash_chain4(current, 4)

            levels[level * 4] = incoming
            levels[level * 4 + 1] = 0
            levels[level * 4 + 2] = 0
            levels[level * 4 + 3] = 0
            lengths[level] = 1
            level += 1
        }

        i += 1
    }

    let mut level_lengths: u256 = 0
    let mut digests = [0; LAZY_TOWER_HEIGHT]
    let mut height: usize = 0
    let mut level: usize = 0
    while level < LAZY_TOWER_HEIGHT {
        let len = lengths[level]
        if len != 0 {
            level_lengths += (len as u256) << ((level * LAZY_TOWER_BITS_PER_LEVEL) as u256)
            let current = [
                levels[level * 4],
                levels[level * 4 + 1],
                levels[level * 4 + 2],
                levels[level * 4 + 3],
            ]
            digests[level] = hash_chain4(current, len)
            height = level + 1
        }
        level += 1
    }

    let mut digest_of_digests = digests[height - 1]
    if height > 1 {
        let mut level = height - 1
        while level != 0 {
            level -= 1
            digest_of_digests = hash2(digest_of_digests, digests[level])
        }
    }

    (level_lengths, digests, digest_of_digests)
}

#[test]
fn test_lazytower_level_lengths_matches_solidity() {
    let tower = lazytower_after_150()
    assert(tower.level_lengths == 0x2112)
}

#[test]
fn test_lazytower_digest_0_matches_solidity() {
    let tower = lazytower_after_150()
    assert(
        tower.digests[0]
            == 7484852499570635450337779587061833141700590058395918107227385307780465498841,
    )
}

#[test]
fn test_lazytower_digest_1_matches_solidity() {
    let tower = lazytower_after_150()
    assert(
        tower.digests[1]
            == 18801712394745483811033456933953954791894699812924877968490149877093764724813,
    )
}

#[test]
fn test_lazytower_digest_2_matches_solidity() {
    let tower = lazytower_after_150()
    assert(
        tower.digests[2]
            == 18495397265763935736123111771752209927150052777598404957994272011704245682779,
    )
}

#[test]
fn test_lazytower_digest_3_matches_solidity() {
    let tower = lazytower_after_150()
    assert(
        tower.digests[3]
            == 11606235313340788975553986881206148975708550071371494991713397040288897077102,
    )
}

#[test]
fn test_lazytower_digest_of_digests_matches_solidity() {
    let tower = lazytower_after_150()
    assert(
        tower.digest_of_digests[0]
            == 19260615748091768530426964318883829655407684674262674118201416393073357631548,
    )
}

#[test]
fn test_lazytower_shift_tower_matches_solidity() {
    let (level_lengths, digests, digest_of_digests) = lazytower_shift_tower_after_150()
    assert(level_lengths == 0x2112)
    assert(
        digests[0] == 7484852499570635450337779587061833141700590058395918107227385307780465498841,
    )
    assert(
        digests[1] == 18801712394745483811033456933953954791894699812924877968490149877093764724813,
    )
    assert(
        digests[2] == 18495397265763935736123111771752209927150052777598404957994272011704245682779,
    )
    assert(
        digests[3] == 11606235313340788975553986881206148975708550071371494991713397040288897077102,
    )
    assert(
        digest_of_digests
            == 19260615748091768530426964318883829655407684674262674118201416393073357631548,
    )
}

#[test]
fn test_lazytower_find_lowest_non_full_level_matches_shift_tower() {
    let mut lengths: [usize; LAZY_TOWER_HEIGHT] = [0; LAZY_TOWER_HEIGHT]
    let mut level_lengths: u256 = 0
    let mut i: usize = 0

    while i < 150 {
        let mut expected_level: usize = 0
        while lengths[expected_level] == 4 {
            expected_level += 1
        }
        let expected_is_head = lengths[expected_level] == 0

        let mut expected_is_top = true
        let mut higher: usize = expected_level + 1
        while higher < LAZY_TOWER_HEIGHT {
            if lengths[higher] != 0 {
                expected_is_top = false
                break
            }
            higher += 1
        }

        let (
            level,
            is_head,
            is_top,
            next_level_lengths,
        ) = LazyTowerHashChainData::find_lowest_non_full_level_then_inc(level_lengths)
        assert(level == expected_level)
        assert(is_head == expected_is_head)
        assert(is_top == expected_is_top)

        let mut carry = true
        let mut level: usize = 0
        while carry {
            if lengths[level] < 4 {
                lengths[level] += 1
                carry = false
            } else {
                lengths[level] = 1
                level += 1
            }
        }

        let mut expected_level_lengths: u256 = 0
        let mut level: usize = 0
        while level < LAZY_TOWER_HEIGHT {
            expected_level_lengths += ((lengths[level] as u256) << ((level * LAZY_TOWER_BITS_PER_LEVEL) as u256))
            level += 1
        }

        assert(next_level_lengths == expected_level_lengths)
        level_lengths = next_level_lengths
        i += 1
    }
}

#[test]
fn test_lazytower_vectors_match_solidity() {
    let tower = lazytower_after_150()

    let (level_lengths, digests, digest_of_digests) = tower.get_data_for_proving()

    assert(level_lengths == 0x2112)
    assert(tower.level_lengths == 0x2112)
    assert(
        tower.digests[0]
            == 7484852499570635450337779587061833141700590058395918107227385307780465498841,
    )
    assert(
        tower.digests[1]
            == 18801712394745483811033456933953954791894699812924877968490149877093764724813,
    )
    assert(
        tower.digests[2]
            == 18495397265763935736123111771752209927150052777598404957994272011704245682779,
    )
    assert(
        tower.digests[3]
            == 11606235313340788975553986881206148975708550071371494991713397040288897077102,
    )
    assert(
        tower.digest_of_digests[0]
            == 19260615748091768530426964318883829655407684674262674118201416393073357631548,
    )
    assert(
        digests[0] == 7484852499570635450337779587061833141700590058395918107227385307780465498841,
    )
    assert(
        digests[1] == 18801712394745483811033456933953954791894699812924877968490149877093764724813,
    )
    assert(
        digests[2] == 18495397265763935736123111771752209927150052777598404957994272011704245682779,
    )
    assert(
        digests[3] == 11606235313340788975553986881206148975708550071371494991713397040288897077102,
    )

    let mut i: usize = 4
    while i < LAZY_TOWER_HEIGHT {
        assert(digests[i] == 0)
        i += 1
    }

    assert(
        digest_of_digests
            == 19260615748091768530426964318883829655407684674262674118201416393073357631548,
    )
}

#[test]
fn test_lazytower_rejects_out_of_field_values() {
    let mut tower = LazyTowerHashChainData::empty()
    let err = tower.add(SNARK_SCALAR_FIELD - 1)
    assert(err.code() == LazyTowerError::None.code())

    let err = tower.add(SNARK_SCALAR_FIELD)
    assert(err.code() == LazyTowerError::ItemMustBeInField.code())
}

