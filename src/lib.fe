msg GitcoinPassportExcubiaMsg {
    #[selector = 0x55000001]
    SetGate { gate: Address } -> u256,
    #[selector = 0x55000002]
    Check { passerby: Address } -> u256,
    #[selector = 0x55000003]
    Pass { passerby: Address } -> u256,
    #[selector = 0x55000004]
    Gate -> u256,
    #[selector = 0x55000005]
    Trait -> u256,
    #[selector = 0x55000006]
    HasPassed { passerby: Address } -> bool,
}

struct GitcoinPassportExcubiaStore {
    owner: Address,
    gate: Address,
    decoder: Address,
    threshold_score: u256,
    passed_users: StorageMap<Address, bool>,
}

pub contract GitcoinPassportExcubia uses (ctx: Ctx, call: mut Call, log: mut Log) {
    mut store: GitcoinPassportExcubiaStore

    init(decoder: Address, threshold_score: u256) uses (mut store, ctx) {
        assert(decoder != Address::zero())
        assert(threshold_score > 0)
        store.owner = ctx.caller()
        store.gate = Address::zero()
        store.decoder = decoder
        store.threshold_score = threshold_score
    }

    recv GitcoinPassportExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(store.owner, store.gate, ctx.caller(), gate)
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check { passerby } -> u256 uses (store, mut call) {
            let score: u256 = call.call(
                addr: store.decoder,
                gas: 100000,
                value: 0,
                message: MockGitcoinPassportDecoderMsg::GetScore { user: passerby },
            )
            if (score / GITCOIN_SCORE_FACTOR) < store.threshold_score {
                return ExcubiaError::InsufficientScore.code()
            }
            ExcubiaError::None.code()
        }

        Pass { passerby } -> u256 uses (mut store, ctx, mut call, mut log) {
            let err = excubia_gate_only_err(store.gate, ctx.caller())
            if !err.is_none() {
                return err.code()
            }
            if store.passed_users.get(key: passerby) {
                return ExcubiaError::AlreadyPassed.code()
            }

            let score: u256 = call.call(
                addr: store.decoder,
                gas: 100000,
                value: 0,
                message: MockGitcoinPassportDecoderMsg::GetScore { user: passerby },
            )
            if (score / GITCOIN_SCORE_FACTOR) < store.threshold_score {
                return ExcubiaError::InsufficientScore.code()
            }

            store.passed_users.set(key: passerby, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_GITCOIN_PASSPORT
        }

        HasPassed { passerby } -> bool uses (store) {
            store.passed_users.get(key: passerby)
        }
    }
}

