#[test]
fn test_poseidon_t6_vectors_match_reference() {
    assert(
        hash5(0, 0, 0, 0, 0) == 0x2195f30d8f267ffdae076f6a28f11b1e3c662fa4bcd8a0ce8c18c076f7411d03,
    )
    assert(
        hash5(1, 2, 3, 4, 5) == 0x1cf4ba9128729d4ece966b59e2a2778e7cd043f0d6a7d6b4eb0fc3312e64232c,
    )
}

const QUINARY_ARITY: usize = 5
const QUINARY_SIBLINGS_PER_LEVEL: usize = 4
const QUINARY_LAST_SUBTREES_LEN: usize = MAX_DEPTH * QUINARY_ARITY
const QUINARY_SIBLINGS_LEN: usize = MAX_DEPTH * QUINARY_SIBLINGS_PER_LEVEL

fn hash5_nodes(nodes: [u256; QUINARY_ARITY]) -> u256 {
    hash5(nodes[0], nodes[1], nodes[2], nodes[3], nodes[4])
}

fn quinary_subtree_slot(level: usize, pos: usize) -> usize {
    level * QUINARY_ARITY + pos
}

fn quinary_sibling_slot(level: usize, pos: usize) -> usize {
    level * QUINARY_SIBLINGS_PER_LEVEL + pos
}

fn quinary_capacity(depth: usize) -> usize {
    let mut cap: usize = 1
    let mut i: usize = 0

    while i < depth {
        cap *= QUINARY_ARITY
        i += 1
    }

    cap
}

pub struct QuinaryIMTData {
    pub depth: usize,
    pub root: u256,
    pub number_of_leaves: usize,
    pub zeroes: [u256; MAX_DEPTH],
    pub last_subtrees: [u256; QUINARY_LAST_SUBTREES_LEN],
}

impl QuinaryIMTData {
    pub fn empty() -> Self {
        QuinaryIMTData {
            depth: 0,
            root: 0,
            number_of_leaves: 0,
            zeroes: [0; MAX_DEPTH],
            last_subtrees: [0; QUINARY_LAST_SUBTREES_LEN],
        }
    }
    pub fn init(mut self, depth: usize, zero: u256) -> IMTError {
        if zero >= SNARK_SCALAR_FIELD {
            return IMTError::ValueGreaterThanSnarkScalarField
        }

        if depth == 0 || depth > MAX_DEPTH {
            return IMTError::DepthNotSupported
        }

        self.depth = depth
        self.number_of_leaves = 0
        self.zeroes = [0; MAX_DEPTH]
        self.last_subtrees = [0; QUINARY_LAST_SUBTREES_LEN]

        let mut current_zero = zero
        let mut i: usize = 0

        while i < depth {
            self.zeroes[i] = current_zero
            current_zero = hash5(
                current_zero,
                current_zero,
                current_zero,
                current_zero,
                current_zero,
            )
            i += 1
        }

        self.root = current_zero

        IMTError::None
    }
    pub fn insert(mut self, leaf: u256) -> (u256, IMTError) {
        if self.depth == 0 || self.depth > MAX_DEPTH {
            return (0, IMTError::DepthNotSupported)
        }

        if leaf >= SNARK_SCALAR_FIELD {
            return (0, IMTError::ValueGreaterThanSnarkScalarField)
        }

        let capacity = quinary_capacity(self.depth)
        if self.number_of_leaves >= capacity {
            return (0, IMTError::TreeIsFull)
        }

        let mut index = self.number_of_leaves
        let mut h = leaf
        let mut i: usize = 0

        while i < self.depth {
            let position = index % QUINARY_ARITY
            self.last_subtrees[quinary_subtree_slot(i, position)] = h

            if position == 0 {
                let mut j: usize = 1
                while j < QUINARY_ARITY {
                    self.last_subtrees[quinary_subtree_slot(i, j)] = self.zeroes[i]
                    j += 1
                }
            }

            let nodes: [u256; QUINARY_ARITY] = [
                self.last_subtrees[quinary_subtree_slot(i, 0)],
                self.last_subtrees[quinary_subtree_slot(i, 1)],
                self.last_subtrees[quinary_subtree_slot(i, 2)],
                self.last_subtrees[quinary_subtree_slot(i, 3)],
                self.last_subtrees[quinary_subtree_slot(i, 4)],
            ]
            h = hash5_nodes(nodes)
            index /= QUINARY_ARITY
            i += 1
        }

        self.root = h
        self.number_of_leaves += 1

        (h, IMTError::None)
    }
    pub fn verify(
        self,
        leaf: u256,
        siblings: [u256; QUINARY_SIBLINGS_LEN],
        indices: [u8; MAX_DEPTH],
    ) -> (bool, IMTError) {
        if self.depth == 0 || self.depth > MAX_DEPTH {
            return (false, IMTError::DepthNotSupported)
        }

        if leaf >= SNARK_SCALAR_FIELD {
            return (false, IMTError::ValueGreaterThanSnarkScalarField)
        }

        let mut h = leaf
        let mut i: usize = 0

        while i < self.depth {
            let path = indices[i]
            if path >= 5 {
                return (false, IMTError::WrongMerkleProofPath)
            }
            let path_usize = path as usize

            let mut nodes: [u256; QUINARY_ARITY] = [0; QUINARY_ARITY]
            let mut j: usize = 0
            while j < QUINARY_ARITY {
                if j < path_usize {
                    if siblings[quinary_sibling_slot(i, j)] >= SNARK_SCALAR_FIELD {
                        return (false, IMTError::ValueGreaterThanSnarkScalarField)
                    }
                    nodes[j] = siblings[quinary_sibling_slot(i, j)]
                } else if j == path_usize {
                    nodes[j] = h
                } else {
                    if siblings[quinary_sibling_slot(i, j - 1)] >= SNARK_SCALAR_FIELD {
                        return (false, IMTError::ValueGreaterThanSnarkScalarField)
                    }
                    nodes[j] = siblings[quinary_sibling_slot(i, j - 1)]
                }

                j += 1
            }

            h = hash5_nodes(nodes)
            i += 1
        }

        (h == self.root, IMTError::None)
    }
    pub fn update(
        mut self,
        leaf: u256,
        new_leaf: u256,
        siblings: [u256; QUINARY_SIBLINGS_LEN],
        indices: [u8; MAX_DEPTH],
    ) -> IMTError {
        if new_leaf == leaf {
            return IMTError::NewLeafCannotEqualOldLeaf
        }

        if new_leaf >= SNARK_SCALAR_FIELD {
            return IMTError::ValueGreaterThanSnarkScalarField
        }

        let (ok, err) = self.verify(leaf, siblings, indices)
        if !err.is_none() {
            return err
        }
        if !ok {
            return IMTError::LeafDoesNotExist
        }

        let mut h = new_leaf
        let mut i: usize = 0
        let mut update_index: usize = 0
        let mut radix: usize = 1

        while i < self.depth {
            let path = indices[i]
            let path_usize = path as usize
            update_index += path_usize * radix
            radix *= QUINARY_ARITY

            let mut nodes: [u256; QUINARY_ARITY] = [0; QUINARY_ARITY]
            let mut j: usize = 0
            while j < QUINARY_ARITY {
                if j < path_usize {
                    nodes[j] = siblings[quinary_sibling_slot(i, j)]
                }
                if j == path_usize {
                    nodes[j] = h
                }
                if j > path_usize {
                    nodes[j] = siblings[quinary_sibling_slot(i, j - 1)]
                }

                j += 1
            }

            if nodes[0] == self.last_subtrees[quinary_subtree_slot(i, 0)]
                || nodes[QUINARY_ARITY - 1]
                    == self.last_subtrees[quinary_subtree_slot(i, QUINARY_ARITY - 1)] {
                self.last_subtrees[quinary_subtree_slot(i, path_usize)] = h
            }

            h = hash5_nodes(nodes)
            i += 1
        }

        if update_index >= self.number_of_leaves {
            return IMTError::LeafIndexOutOfRange
        }

        self.root = h
        IMTError::None
    }
    pub fn remove(
        mut self,
        leaf: u256,
        siblings: [u256; QUINARY_SIBLINGS_LEN],
        indices: [u8; MAX_DEPTH],
    ) -> IMTError {
        self.update(leaf, self.zeroes[0], siblings, indices)
    }
}

#[test]
fn test_quinary_init_and_tree_full() {
    let mut tree = QuinaryIMTData::empty()

    let err = tree.init(1, 0)
    assert(err.code() == IMTError::None.code())
    assert(
        tree.root == 0x2195f30d8f267ffdae076f6a28f11b1e3c662fa4bcd8a0ce8c18c076f7411d03,
    )

    let (_root, err) = tree.insert(1)
    assert(err.code() == IMTError::None.code())
    let (_root, err) = tree.insert(2)
    assert(err.code() == IMTError::None.code())
    let (_root, err) = tree.insert(3)
    assert(err.code() == IMTError::None.code())
    let (_root, err) = tree.insert(4)
    assert(err.code() == IMTError::None.code())
    let (_root, err) = tree.insert(5)
    assert(err.code() == IMTError::None.code())

    let (_root, err) = tree.insert(6)
    assert(err.code() == IMTError::TreeIsFull.code())
}

#[test]
fn test_quinary_verify_update_remove_roundtrip() {
    let mut tree = QuinaryIMTData::empty()
    let err = tree.init(2, 0)
    assert(err.code() == IMTError::None.code())
    assert(
        tree.root == 0x01dd0a79d1c4a015b192cd3518ea0d5509859740bb781290bc073c6bbbb7cf32,
    )

    let (_root, err) = tree.insert(1)
    assert(err.code() == IMTError::None.code())
    let (_root, err) = tree.insert(2)
    assert(err.code() == IMTError::None.code())
    let (_root, err) = tree.insert(3)
    assert(err.code() == IMTError::None.code())
    assert(
        tree.root == 0x0b5267fd8f77fb03c6d639ed6fd8544cb4c03fa63b070592d301790160485668,
    )

    let mut indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    indices[0] = 2
    indices[1] = 0

    let z1 = tree.zeroes[1]

    let mut siblings: [u256; QUINARY_SIBLINGS_LEN] = [0; QUINARY_SIBLINGS_LEN]
    siblings[quinary_sibling_slot(0, 0)] = 1
    siblings[quinary_sibling_slot(0, 1)] = 2
    siblings[quinary_sibling_slot(0, 2)] = 0
    siblings[quinary_sibling_slot(0, 3)] = 0
    siblings[quinary_sibling_slot(1, 0)] = z1
    siblings[quinary_sibling_slot(1, 1)] = z1
    siblings[quinary_sibling_slot(1, 2)] = z1
    siblings[quinary_sibling_slot(1, 3)] = z1

    let (ok, err) = tree.verify(3, siblings, indices)
    assert(err.code() == IMTError::None.code())
    assert(ok)

    let err = tree.update(3, 9, siblings, indices)
    assert(err.code() == IMTError::None.code())
    assert(
        tree.root == 0x1b5022d615316fa5003498572e259df035248d113dabeb01a17542945b9e470a,
    )

    let (ok, err) = tree.verify(9, siblings, indices)
    assert(err.code() == IMTError::None.code())
    assert(ok)

    let err = tree.remove(9, siblings, indices)
    assert(err.code() == IMTError::None.code())
    assert(
        tree.root == 0x0594155ca26cf6ec0a8e614599183d3087d0499d57d3c584e75244b9a5ace827,
    )

    let (ok, err) = tree.verify(0, siblings, indices)
    assert(err.code() == IMTError::None.code())
    assert(ok)
}

#[test]
fn test_quinary_invalid_path_index_error() {
    let mut tree = QuinaryIMTData::empty()
    let err = tree.init(1, 0)
    assert(err.code() == IMTError::None.code())

    let mut indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    indices[0] = 5

    let siblings: [u256; QUINARY_SIBLINGS_LEN] = [0; QUINARY_SIBLINGS_LEN]

    let (_ok, err) = tree.verify(1, siblings, indices)
    assert(err.code() == IMTError::WrongMerkleProofPath.code())
}

#[test]
fn test_quinary_init_and_update_error_cases() {
    let mut tree = QuinaryIMTData::empty()

    let err = tree.init(0, 0)
    assert(err.code() == IMTError::DepthNotSupported.code())

    let err = tree.init(33, 0)
    assert(err.code() == IMTError::DepthNotSupported.code())

    let err = tree.init(1, SNARK_SCALAR_FIELD)
    assert(
        err.code() == IMTError::ValueGreaterThanSnarkScalarField.code(),
    )

    let err = tree.init(1, 0)
    assert(err.code() == IMTError::None.code())

    let (_root, err) = tree.insert(SNARK_SCALAR_FIELD)
    assert(
        err.code() == IMTError::ValueGreaterThanSnarkScalarField.code(),
    )

    let (_root, err) = tree.insert(1)
    assert(err.code() == IMTError::None.code())

    let indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    let siblings: [u256; QUINARY_SIBLINGS_LEN] = [0; QUINARY_SIBLINGS_LEN]

    let err = tree.update(1, 1, siblings, indices)
    assert(err.code() == IMTError::NewLeafCannotEqualOldLeaf.code())

    let err = tree.update(1, SNARK_SCALAR_FIELD, siblings, indices)
    assert(
        err.code() == IMTError::ValueGreaterThanSnarkScalarField.code(),
    )

    let err = tree.update(SNARK_SCALAR_FIELD, 2, siblings, indices)
    assert(
        err.code() == IMTError::ValueGreaterThanSnarkScalarField.code(),
    )

    let mut bad_indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    bad_indices[0] = 5
    let err = tree.update(1, 2, siblings, bad_indices)
    assert(err.code() == IMTError::WrongMerkleProofPath.code())

    let err = tree.update(2, 3, siblings, indices)
    assert(err.code() == IMTError::LeafDoesNotExist.code())

    let err = tree.remove(SNARK_SCALAR_FIELD, siblings, indices)
    assert(
        err.code() == IMTError::ValueGreaterThanSnarkScalarField.code(),
    )

    let err = tree.remove(2, siblings, indices)
    assert(err.code() == IMTError::LeafDoesNotExist.code())
}

#[test]
fn test_quinary_leaf_index_out_of_range() {
    let mut tree = QuinaryIMTData::empty()
    let err = tree.init(2, 0)
    assert(err.code() == IMTError::None.code())

    let (_root, err) = tree.insert(1)
    assert(err.code() == IMTError::None.code())
    let (_root, err) = tree.insert(2)
    assert(err.code() == IMTError::None.code())
    let (_root, err) = tree.insert(3)
    assert(err.code() == IMTError::None.code())
    let (_root, err) = tree.insert(4)
    assert(err.code() == IMTError::None.code())

    let z1 = tree.zeroes[1]

    let mut indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    indices[0] = 4

    let mut siblings: [u256; QUINARY_SIBLINGS_LEN] = [0; QUINARY_SIBLINGS_LEN]
    siblings[quinary_sibling_slot(0, 0)] = 1
    siblings[quinary_sibling_slot(0, 1)] = 2
    siblings[quinary_sibling_slot(0, 2)] = 3
    siblings[quinary_sibling_slot(0, 3)] = 4
    siblings[quinary_sibling_slot(1, 0)] = z1
    siblings[quinary_sibling_slot(1, 1)] = z1
    siblings[quinary_sibling_slot(1, 2)] = z1
    siblings[quinary_sibling_slot(1, 3)] = z1

    let err = tree.update(0, 42, siblings, indices)
    assert(err.code() == IMTError::LeafIndexOutOfRange.code())
}

#[test]
fn test_quinary_insert_after_remove_preserves_holes() {
    let mut tree = QuinaryIMTData::empty()
    let err = tree.init(2, 0)
    assert(err.code() == IMTError::None.code())

    let (_root, err) = tree.insert(1)
    assert(err.code() == IMTError::None.code())

    let z1 = tree.zeroes[1]

    let remove_indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    let mut remove_siblings: [u256; QUINARY_SIBLINGS_LEN] = [0; QUINARY_SIBLINGS_LEN]
    remove_siblings[quinary_sibling_slot(1, 0)] = z1
    remove_siblings[quinary_sibling_slot(1, 1)] = z1
    remove_siblings[quinary_sibling_slot(1, 2)] = z1
    remove_siblings[quinary_sibling_slot(1, 3)] = z1

    let err = tree.remove(1, remove_siblings, remove_indices)
    assert(err.code() == IMTError::None.code())

    let (_root, err) = tree.insert(2)
    assert(err.code() == IMTError::None.code())

    let level0 = hash5_nodes([0, 2, 0, 0, 0])
    let expected_root = hash5(level0, z1, z1, z1, z1)
    assert(tree.root == expected_root)

    let mut indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    indices[0] = 1

    let mut siblings: [u256; QUINARY_SIBLINGS_LEN] = [0; QUINARY_SIBLINGS_LEN]
    siblings[quinary_sibling_slot(1, 0)] = z1
    siblings[quinary_sibling_slot(1, 1)] = z1
    siblings[quinary_sibling_slot(1, 2)] = z1
    siblings[quinary_sibling_slot(1, 3)] = z1

    let (ok, err) = tree.verify(2, siblings, indices)
    assert(err.code() == IMTError::None.code())
    assert(ok)
}

const MAX_DEPTH_PLUS_ONE: usize = MAX_DEPTH + 1
const LAZY_MAP_CAPACITY: usize = 256
const LAZY_MAP_CAPACITY_U256: u256 = 256
const LAZY_MAX_INDEX: u256 = 4294967295

pub enum LazyIMTError {
    None,
    TreeTooLarge,
    LeafMustBeInField,
    TreeIsFull,
    LeafMustExist,
    DepthMustBePositive,
    DepthTooLarge,
    AmbiguousDepth,
    ProofDepthTooSmall,
    DefaultZeroBadIndex,
    SparseMapFull,
}

impl LazyIMTError {
    pub fn is_none(self) -> bool {
        match self {
            LazyIMTError::None => true,
            _ => false,
        }
    }
    pub fn code(self) -> u256 {
        match self {
            LazyIMTError::None => 0,
            LazyIMTError::TreeTooLarge => 1,
            LazyIMTError::LeafMustBeInField => 2,
            LazyIMTError::TreeIsFull => 3,
            LazyIMTError::LeafMustExist => 4,
            LazyIMTError::DepthMustBePositive => 5,
            LazyIMTError::DepthTooLarge => 6,
            LazyIMTError::AmbiguousDepth => 7,
            LazyIMTError::ProofDepthTooSmall => 8,
            LazyIMTError::DefaultZeroBadIndex => 9,
            LazyIMTError::SparseMapFull => 10,
        }
    }
}

pub struct LazyIMTData {
    pub max_index: usize,
    pub number_of_leaves: usize,
    pub element_used: [u8; LAZY_MAP_CAPACITY],
    pub element_keys: [u256; LAZY_MAP_CAPACITY],
    pub element_values: [u256; LAZY_MAP_CAPACITY],
}

impl LazyIMTData {
    pub fn empty() -> Self {
        LazyIMTData {
            max_index: 0,
            number_of_leaves: 0,
            element_used: [0; LAZY_MAP_CAPACITY],
            element_keys: [0; LAZY_MAP_CAPACITY],
            element_values: [0; LAZY_MAP_CAPACITY],
        }
    }
    pub fn default_zero(index: usize) -> (u256, LazyIMTError) {
        if index > MAX_DEPTH {
            return (0, LazyIMTError::DefaultZeroBadIndex)
        }

        (BinaryIMTData::default_zero(index), LazyIMTError::None)
    }
    pub fn init(mut self, depth: usize) -> LazyIMTError {
        if depth > MAX_DEPTH {
            return LazyIMTError::TreeTooLarge
        }

        if depth == 0 {
            self.max_index = 0
        } else {
            self.max_index = (1 << depth) - 1
        }
        self.number_of_leaves = 0
        self.element_used = [0; LAZY_MAP_CAPACITY]
        self.element_keys = [0; LAZY_MAP_CAPACITY]
        self.element_values = [0; LAZY_MAP_CAPACITY]

        LazyIMTError::None
    }
    pub fn reset(mut self) {
        self.number_of_leaves = 0
    }
    pub fn index_for_element(level: usize, index: usize) -> u256 {
        (level as u256) * LAZY_MAX_INDEX + (index as u256)
    }

    fn element_get(self, level: usize, index: usize) -> (bool, u256) {
        let key = LazyIMTData::index_for_element(level, index)
        let mut slot = (key % LAZY_MAP_CAPACITY_U256) as usize
        let mut i: usize = 0

        while i < LAZY_MAP_CAPACITY {
            if self.element_used[slot] == 0 {
                return (false, 0)
            }

            if self.element_keys[slot] == key {
                return (true, self.element_values[slot])
            }

            slot += 1
            if slot == LAZY_MAP_CAPACITY {
                slot = 0
            }
            i += 1
        }

        (false, 0)
    }

    fn element_set(mut self, level: usize, index: usize, value: u256) -> LazyIMTError {
        let key = LazyIMTData::index_for_element(level, index)
        let mut slot = (key % LAZY_MAP_CAPACITY_U256) as usize
        let mut i: usize = 0

        while i < LAZY_MAP_CAPACITY {
            if self.element_used[slot] == 0 {
                self.element_used[slot] = 1
                self.element_keys[slot] = key
                self.element_values[slot] = value
                return LazyIMTError::None
            }

            if self.element_keys[slot] == key {
                self.element_values[slot] = value
                return LazyIMTError::None
            }

            slot += 1
            if slot == LAZY_MAP_CAPACITY {
                slot = 0
            }
            i += 1
        }

        LazyIMTError::SparseMapFull
    }
    pub fn insert(mut self, leaf: u256) -> LazyIMTError {
        let mut index = self.number_of_leaves
        if leaf >= SNARK_SCALAR_FIELD {
            return LazyIMTError::LeafMustBeInField
        }
        if index > self.max_index {
            return LazyIMTError::TreeIsFull
        }

        self.number_of_leaves = index + 1
        let mut h = leaf
        let mut level: usize = 0

        while true {
            let err = self.element_set(level, index, h)
            if !err.is_none() {
                return err
            }

            if index & 1 == 0 {
                return LazyIMTError::None
            }

            let (ok, left) = self.element_get(level, index - 1)
            if !ok {
                return LazyIMTError::LeafMustExist
            }

            h = hash2(left, h)
            index = index >> 1
            level += 1
        }

        LazyIMTError::None
    }
    pub fn update(mut self, leaf: u256, index: usize) -> LazyIMTError {
        if leaf >= SNARK_SCALAR_FIELD {
            return LazyIMTError::LeafMustBeInField
        }
        if index >= self.number_of_leaves {
            return LazyIMTError::LeafMustExist
        }

        let number_of_leaves = self.number_of_leaves
        let mut h = leaf
        let mut index = index
        let mut level: usize = 0

        while true {
            let err = self.element_set(level, index, h)
            if !err.is_none() {
                return err
            }

            let level_count = number_of_leaves >> (level + 1)
            if level_count <= (index >> 1) {
                return LazyIMTError::None
            }

            if index & 1 == 0 {
                let (ok, right) = self.element_get(level, index + 1)
                if !ok {
                    return LazyIMTError::LeafMustExist
                }
                h = hash2(h, right)
            } else {
                let (ok, left) = self.element_get(level, index - 1)
                if !ok {
                    return LazyIMTError::LeafMustExist
                }
                h = hash2(left, h)
            }

            index = index >> 1
            level += 1
        }

        LazyIMTError::None
    }

    fn levels_for_root(self, number_of_leaves: usize, depth: usize) -> (
        [u256; MAX_DEPTH_PLUS_ONE],
        LazyIMTError,
    ) {
        let mut levels: [u256; MAX_DEPTH_PLUS_ONE] = [0; MAX_DEPTH_PLUS_ONE]
        if depth > MAX_DEPTH {
            return (levels, LazyIMTError::DepthTooLarge)
        }
        if number_of_leaves == 0 {
            return (levels, LazyIMTError::LeafMustExist)
        }

        let mut index = number_of_leaves - 1

        if index & 1 == 0 {
            let (ok, value) = self.element_get(0, index)
            if ok { levels[0] = value }
        } else {
            levels[0] = BinaryIMTData::default_zero(0)
        }

        let mut i: usize = 0
        while i < depth {
            if index & 1 == 0 {
                levels[i + 1] = hash2(levels[i], BinaryIMTData::default_zero(i))
            } else {
                let level_count = number_of_leaves >> (i + 1)
                if level_count > (index >> 1) {
                    let (ok, parent) = self.element_get(i + 1, index >> 1)
                    if ok {
                        levels[i + 1] = parent
                    } else {
                        levels[i + 1] = BinaryIMTData::default_zero(i + 1)
                    }
                } else {
                    let (ok, sibling) = self.element_get(i, index - 1)
                    if ok {
                        levels[i + 1] = hash2(sibling, levels[i])
                    } else {
                        levels[i + 1] = hash2(BinaryIMTData::default_zero(i), levels[i])
                    }
                }
            }

            index = index >> 1
            i += 1
        }

        (levels, LazyIMTError::None)
    }

    fn root_for(self, number_of_leaves: usize, depth: usize) -> (u256, LazyIMTError) {
        if depth > MAX_DEPTH {
            return (0, LazyIMTError::DepthTooLarge)
        }

        if number_of_leaves == 0 {
            return (BinaryIMTData::default_zero(depth), LazyIMTError::None)
        }

        let (levels, err) = self.levels_for_root(number_of_leaves, depth)
        if !err.is_none() {
            return (0, err)
        }

        (levels[depth], LazyIMTError::None)
    }
    pub fn root(self) -> (u256, LazyIMTError) {
        let number_of_leaves = self.number_of_leaves
        let mut depth: usize = 1
        let mut bound: usize = 2
        while bound < number_of_leaves {
            bound = bound << 1
            depth += 1
        }

        self.root_for(number_of_leaves, depth)
    }
    pub fn root_at_depth(self, depth: usize) -> (u256, LazyIMTError) {
        if depth == 0 {
            return (0, LazyIMTError::DepthMustBePositive)
        }
        if depth > MAX_DEPTH {
            return (0, LazyIMTError::DepthTooLarge)
        }

        let number_of_leaves = self.number_of_leaves
        if (1 << depth) < number_of_leaves {
            return (0, LazyIMTError::AmbiguousDepth)
        }

        self.root_for(number_of_leaves, depth)
    }
    pub fn merkle_proof_elements(self, index: usize, depth: usize) -> (
        [u256; MAX_DEPTH],
        LazyIMTError,
    ) {
        let mut elements: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
        let number_of_leaves = self.number_of_leaves

        if index >= number_of_leaves {
            return (elements, LazyIMTError::LeafMustExist)
        }
        let mut index = index

        let mut target_depth: usize = 1
        let mut val: usize = 2
        while val < number_of_leaves {
            val = val << 1
            target_depth += 1
        }

        if depth < target_depth {
            return (elements, LazyIMTError::ProofDepthTooSmall)
        }

        if target_depth > 1 {
            let (levels, err) = self.levels_for_root(number_of_leaves, target_depth - 1)
            if !err.is_none() {
                return (elements, err)
            }

            let mut i: usize = 0
            while i < target_depth {
                elements[i] = levels[i]
                i += 1
            }
        }

        if index & 1 == 0 {
            if index + 1 >= number_of_leaves {
                elements[0] = BinaryIMTData::default_zero(0)
            } else {
                let (ok, sibling) = self.element_get(0, index + 1)
                if ok {
                    elements[0] = sibling
                }
            }
        } else {
            let (ok, sibling) = self.element_get(0, index - 1)
            if ok {
                elements[0] = sibling
            }
        }

        index = index >> 1

        let mut i: usize = 1
        while i < depth {
            let current_level_count = number_of_leaves >> i
            if index & 1 == 0 {
                if index + 1 < current_level_count {
                    let (ok, sibling) = self.element_get(i, index + 1)
                    if ok {
                        elements[i] = sibling
                    }
                } else if ((number_of_leaves - 1) >> i) <= index {
                    elements[i] = BinaryIMTData::default_zero(i)
                }
            } else {
                let (ok, sibling) = self.element_get(i, index - 1)
                if ok {
                    elements[i] = sibling
                }
            }

            index = index >> 1
            i += 1
        }

        (elements, LazyIMTError::None)
    }
}

fn lazy_calculate_root(
    leaf_index: usize,
    leaf: u256,
    proof_depth: usize,
    proof_elements: [u256; MAX_DEPTH],
) -> u256 {
    let mut h = leaf
    let mut i: usize = 0

    while i < proof_depth {
        if ((leaf_index >> i) & 1) == 1 {
            h = hash2(proof_elements[i], h)
        } else {
            h = hash2(h, proof_elements[i])
        }

        i += 1
    }

    h
}

#[test]
fn test_lazy_default_zero_and_init() {
    let (z0, err) = LazyIMTData::default_zero(0)
    assert(err.code() == LazyIMTError::None.code())
    assert(z0 == 0)

    let (z2, err) = LazyIMTData::default_zero(2)
    assert(err.code() == LazyIMTError::None.code())
    assert(z2 == BinaryIMTData::default_zero(2))

    let (_z, err) = LazyIMTData::default_zero(33)
    assert(err.code() == LazyIMTError::DefaultZeroBadIndex.code())

    let mut tree = LazyIMTData::empty()
    let err = tree.init(10)
    assert(err.code() == LazyIMTError::None.code())
    assert(tree.max_index == 1023)
    assert(tree.number_of_leaves == 0)

    let mut too_big = LazyIMTData::empty()
    let err = too_big.init(33)
    assert(err.code() == LazyIMTError::TreeTooLarge.code())
}

#[test]
fn test_lazy_insert_update_reset_and_roots() {
    let mut tree = LazyIMTData::empty()
    let err = tree.init(4)
    assert(err.code() == LazyIMTError::None.code())

    let (root, err) = tree.root()
    assert(err.code() == LazyIMTError::None.code())
    assert(root == hash2(0, 0))

    let err = tree.insert(1)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(2)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(3)
    assert(err.code() == LazyIMTError::None.code())

    let (root, err) = tree.root()
    assert(err.code() == LazyIMTError::None.code())
    assert(root == hash2(hash2(1, 2), hash2(3, 0)))

    let err = tree.update(9, 1)
    assert(err.code() == LazyIMTError::None.code())
    let (root, err) = tree.root()
    assert(err.code() == LazyIMTError::None.code())
    assert(root == hash2(hash2(1, 9), hash2(3, 0)))

    tree.reset()
    assert(tree.number_of_leaves == 0)
    let (root, err) = tree.root()
    assert(err.code() == LazyIMTError::None.code())
    assert(root == hash2(0, 0))
}

#[test]
fn test_lazy_error_cases() {
    let mut tree = LazyIMTData::empty()
    let err = tree.init(3)
    assert(err.code() == LazyIMTError::None.code())

    let err = tree.insert(SNARK_SCALAR_FIELD)
    assert(err.code() == LazyIMTError::LeafMustBeInField.code())

    let err = tree.insert(1)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(2)
    assert(err.code() == LazyIMTError::None.code())

    let err = tree.update(SNARK_SCALAR_FIELD, 0)
    assert(err.code() == LazyIMTError::LeafMustBeInField.code())

    let err = tree.update(9, 2)
    assert(err.code() == LazyIMTError::LeafMustExist.code())

    let (_root, err) = tree.root_at_depth(0)
    assert(err.code() == LazyIMTError::DepthMustBePositive.code())
}

#[test]
fn test_lazy_reset_reuses_tree() {
    let mut tree = LazyIMTData::empty()
    let err = tree.init(3)
    assert(err.code() == LazyIMTError::None.code())

    let err = tree.insert(1)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(2)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(3)
    assert(err.code() == LazyIMTError::None.code())

    tree.reset()
    assert(tree.number_of_leaves == 0)

    let err = tree.insert(7)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(8)
    assert(err.code() == LazyIMTError::None.code())

    let (root, err) = tree.root()
    assert(err.code() == LazyIMTError::None.code())
    assert(root == hash2(7, 8))

    let (root_at_depth, err) = tree.root_at_depth(1)
    assert(err.code() == LazyIMTError::None.code())
    assert(root_at_depth == root)
}

#[test]
fn test_lazy_insert_allows_last_leaf_slot() {
    let mut tree = LazyIMTData::empty()
    let err = tree.init(1)
    assert(err.code() == LazyIMTError::None.code())

    let err = tree.insert(11)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(22)
    assert(err.code() == LazyIMTError::None.code())
    assert(tree.number_of_leaves == 2)

    let (root, err) = tree.root()
    assert(err.code() == LazyIMTError::None.code())
    assert(root == hash2(11, 22))

    let err = tree.insert(33)
    assert(err.code() == LazyIMTError::TreeIsFull.code())

    let mut single = LazyIMTData::empty()
    let err = single.init(0)
    assert(err.code() == LazyIMTError::None.code())
    let err = single.insert(7)
    assert(err.code() == LazyIMTError::None.code())
    assert(single.number_of_leaves == 1)
    let err = single.insert(8)
    assert(err.code() == LazyIMTError::TreeIsFull.code())
}

#[test]
fn test_lazy_proof_and_depth_errors() {
    let mut tree = LazyIMTData::empty()
    let err = tree.init(6)
    assert(err.code() == LazyIMTError::None.code())

    let err = tree.insert(1)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(2)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(3)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(4)
    assert(err.code() == LazyIMTError::None.code())
    let err = tree.insert(5)
    assert(err.code() == LazyIMTError::None.code())

    let (proof, err) = tree.merkle_proof_elements(4, 3)
    assert(err.code() == LazyIMTError::None.code())

    let reconstructed = lazy_calculate_root(4, 5, 3, proof)
    let (root, err) = tree.root_at_depth(3)
    assert(err.code() == LazyIMTError::None.code())
    assert(reconstructed == root)

    let (_root, err) = tree.root_at_depth(2)
    assert(err.code() == LazyIMTError::AmbiguousDepth.code())
    let (_root, err) = tree.root_at_depth(33)
    assert(err.code() == LazyIMTError::DepthTooLarge.code())

    let (_proof, err) = tree.merkle_proof_elements(9, 3)
    assert(err.code() == LazyIMTError::LeafMustExist.code())
    let (_proof, err) = tree.merkle_proof_elements(4, 2)
    assert(err.code() == LazyIMTError::ProofDepthTooSmall.code())
}

#[test]
