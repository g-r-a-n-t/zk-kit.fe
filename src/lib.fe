    let mut siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    siblings[0] = 11

    let imt = IMT::new(1, 0)
    let (_ok, err) = imt.verify_checked(SNARK_SCALAR_FIELD, 1, indices, siblings)
