            == 7423237065226347324353380772367382631490014989348495481811164164159255474657,
    )
    assert(
        BinaryIMTData::default_zero(3)
            == 11286972368698509976183087595462810875513684078608517520839298933882497716792,
    )
    assert(
        BinaryIMTData::default_zero(32)
            == 21443572485391568159800782191812935835534334817699172242223315142338162256601,
    )
}

#[test]
fn test_poseidon_vector_depth2_zero0() {
    let mut tree = BinaryIMTData::empty()
    let err = tree.init(2, 0)
    assert(err.code() == IMTError::None.code())

    assert(
        tree.root == 0x1069673dcdb12263df301a6ff584a7ec261a44cb9dc68df067a4774460b1f1e1,
    )

    let (_root, err) = tree.insert(1)
    assert(err.code() == IMTError::None.code())
    assert(
        tree.root == 0x1308fe693bd240b50fdf5f1376bde94de0f1f81c555ef82aaef76120083440c7,
    )

    let (_root, err) = tree.insert(2)
    assert(err.code() == IMTError::None.code())
    assert(
        tree.root == 0x0650fd43e9beb300f190ec831083e4bf15d1cf1462331ccef78d36cf20035385,
    )

    let (_root, err) = tree.insert(3)
    assert(err.code() == IMTError::None.code())
    assert(
        tree.root == 0x0d9e989a60f1961e8fda683cfc3585608a47d513f9af9167c1287fa8cea0720e,
    )

    let mut indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    indices[1] = 1

    let mut siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    siblings[0] = 0
    siblings[1] = 0x115cc0f5e7d690413df64c6b9662e9cf2a3617f2743245519e19607a4417189a

    let (ok, err) = tree.verify(3, siblings, indices)
    assert(err.code() == IMTError::None.code())
    assert(ok)

    let err = tree.update(3, 9, siblings, indices)
    assert(err.code() == IMTError::None.code())
    assert(
        tree.root == 0x1f1bfbedf12a6b50197b37ef3fd4735f8d79af7353ef7e0aeb2579b46227d7fd,
    )

    let (ok, err) = tree.verify(9, siblings, indices)
    assert(err.code() == IMTError::None.code())
    assert(ok)

    let err = tree.remove(9, siblings, indices)
    assert(err.code() == IMTError::None.code())
    assert(
        tree.root == 0x0650fd43e9beb300f190ec831083e4bf15d1cf1462331ccef78d36cf20035385,
    )
}

#[test]
fn test_poseidon_vector_depth2_zero5() {
