    } -> u256,
    #[selector = 0x5c000004]
    Gate -> u256,
    #[selector = 0x5c000005]
    Trait -> u256,
    #[selector = 0x5c000006]
    HasPassedNullifier { nullifier: u256 } -> bool,
}

struct SemaphoreExcubiaStore {
    owner: Address,
    gate: Address,
    semaphore: Address,
    group_id: u256,
    passed_nullifiers: StorageMap<u256, bool>,
}

pub contract SemaphoreExcubia uses (ctx: Ctx, call: mut Call, log: mut Log) {
    mut store: SemaphoreExcubiaStore

    init(semaphore: Address, group_id: u256) uses (mut store, ctx, mut call) {
        assert(semaphore != Address::zero())
        let group_counter: u256 = call.call(
            addr: semaphore,
            gas: 100000,
            value: 0,
            message: MockSemaphoreMsg::GroupCounter {},
        )
        assert(group_counter > group_id)

        store.owner = ctx.caller()
        store.gate = Address::zero()
        store.semaphore = semaphore
        store.group_id = group_id
    }

    recv SemaphoreExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(store.owner, store.gate, ctx.caller(), gate)
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check {
            passerby,
            merkle_tree_depth,
            merkle_tree_root,
            nullifier,
            message_value,
            scope,
            points,
        } -> u256 uses (store, mut call) {
            let _ = passerby
            let _ = merkle_tree_depth
            let _ = merkle_tree_root
            let _ = message_value
            let _ = points
            semaphore_proof_err(
                semaphore: store.semaphore,
                group_id: store.group_id,
                scope: scope,
                nullifier: nullifier,
            )
            .code()
        }

        Pass {
            passerby,
            merkle_tree_depth,
            merkle_tree_root,
            nullifier,
            message_value,
            scope,
            points,
        } -> u256 uses (mut store, ctx, mut call, mut log) {
            let err = excubia_gate_only_err(store.gate, ctx.caller())
            if !err.is_none() {
                return err.code()
            }
            if store.passed_nullifiers.get(key: nullifier) {
                return ExcubiaError::AlreadyPassed.code()
            }

            let _ = passerby
            let _ = merkle_tree_depth
            let _ = merkle_tree_root
            let _ = message_value
            let _ = points

            let err = semaphore_proof_err(
                semaphore: store.semaphore,
                group_id: store.group_id,
                scope: scope,
                nullifier: nullifier,
            )
            if !err.is_none() {
                return err.code()
            }

            store.passed_nullifiers.set(key: nullifier, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_SEMAPHORE
        }

        HasPassedNullifier { nullifier } -> bool uses (store) {
            store.passed_nullifiers.get(key: nullifier)
        }
    }
}

msg ZKEdDSAEventTicketPCDVerifierMsg {
    #[selector = 0x5d000001]
    VerifyProof {
        p_a: [u256; 2],
        p_b: [[u256; 2]; 2],
        p_c: [u256; 2],
        pub_signals: [u256; 38],
    } -> bool,
}

pub contract ZKEdDSAEventTicketPCDVerifier {
    recv ZKEdDSAEventTicketPCDVerifierMsg {
        VerifyProof { p_a, p_b, p_c, pub_signals } -> bool {
            let mut i: usize = 0
            while i < 38 {
                if pub_signals[i] >= ZKEDDSA_R {
                    return false
                }
                i += 1
            }

            let mut vk_x: [u256; 2] = ZKEDDSA_IC[0]
            i = 0
            while i < 38 {
                let (ok, next) = zkeddsa_g1_mul_acc(vk_x, ZKEDDSA_IC[i + 1], pub_signals[i])
                if !ok {
                    return false
                }
                vk_x = next
                i += 1
            }

            zkeddsa_verify_pairing(p_a: p_a, p_b: p_b, p_c: p_c, vk_x: vk_x)
        }
    }
}

msg ZKEdDSAEventTicketPCDExcubiaMsg {
    #[selector = 0x5e000001]
    SetGate { gate: Address } -> u256,
    #[selector = 0x5e000002]
    Check {
        passerby: Address,
        p_a: [u256; 2],
        p_b: [[u256; 2]; 2],
        p_c: [u256; 2],
        pub_signals: [u256; 38],
    } -> u256,
    #[selector = 0x5e000003]
    Pass {
        passerby: Address,
        p_a: [u256; 2],
        p_b: [[u256; 2]; 2],
        p_c: [u256; 2],
        pub_signals: [u256; 38],
    } -> u256,
    #[selector = 0x5e000004]
    Gate -> u256,
    #[selector = 0x5e000005]
    Trait -> u256,
    #[selector = 0x5e000006]
    HasPassedZKEdDSAEventTicketPCD { ticket_id: u256 } -> bool,
}

struct ZKEdDSAEventTicketPCDExcubiaStore {
    owner: Address,
    gate: Address,
    verifier: Address,
    valid_event_id: u256,
    valid_signer_0: u256,
    valid_signer_1: u256,
    passed_ticket_ids: StorageMap<u256, bool>,
}

pub contract ZKEdDSAEventTicketPCDExcubia uses (ctx: Ctx, call: mut Call, log: mut Log) {
    mut store: ZKEdDSAEventTicketPCDExcubiaStore

    init(verifier: Address, valid_event_id: u256, valid_signer_0: u256, valid_signer_1: u256)
        uses (mut store, ctx)
    {
        assert(verifier != Address::zero())
        store.owner = ctx.caller()
        store.gate = Address::zero()
        store.verifier = verifier
        store.valid_event_id = valid_event_id
        store.valid_signer_0 = valid_signer_0
        store.valid_signer_1 = valid_signer_1
    }

    recv ZKEdDSAEventTicketPCDExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(store.owner, store.gate, ctx.caller(), gate)
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check { passerby, p_a, p_b, p_c, pub_signals } -> u256 uses (store, mut call) {
            zkeddsa_proof_err(
                verifier: store.verifier,
                valid_event_id: store.valid_event_id,
                valid_signer_0: store.valid_signer_0,
                valid_signer_1: store.valid_signer_1,
                passerby: passerby,
                p_a: p_a,
                p_b: p_b,
                p_c: p_c,
                pub_signals: pub_signals,
            )
            .code()
        }

        Pass { passerby, p_a, p_b, p_c, pub_signals } -> u256 uses (mut store, ctx, mut call, mut log) {
            let err = excubia_gate_only_err(store.gate, ctx.caller())
            if !err.is_none() {
                return err.code()
            }
            let ticket_id = pub_signals[0]
            if store.passed_ticket_ids.get(key: ticket_id) {
                return ExcubiaError::AlreadyPassed.code()
            }

            let err = zkeddsa_proof_err(
                verifier: store.verifier,
                valid_event_id: store.valid_event_id,
                valid_signer_0: store.valid_signer_0,
                valid_signer_1: store.valid_signer_1,
                passerby: passerby,
                p_a: p_a,
                p_b: p_b,
                p_c: p_c,
                pub_signals: pub_signals,
            )
            if !err.is_none() {
                return err.code()
            }

            store.passed_ticket_ids.set(key: ticket_id, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_ZKEDDSA_EVENT_TICKET_PCD
        }

        HasPassedZKEdDSAEventTicketPCD { ticket_id } -> bool uses (store) {
            store.passed_ticket_ids.get(key: ticket_id)
        }
    }
}

msg ExcubiaCallerMsg {
    #[selector = 0x58000001]
    FreeForAllSetGate { target: Address, gate: Address } -> u256,
    #[selector = 0x58000002]
    FreeForAllPass { target: Address, passerby: Address } -> u256,
    #[selector = 0x58000003]
    ERC721SetGate { target: Address, gate: Address } -> u256,
    #[selector = 0x58000004]
    ERC721Pass { target: Address, passerby: Address, token_id: u256 } -> u256,
    #[selector = 0x58000005]
    GitcoinSetGate { target: Address, gate: Address } -> u256,
    #[selector = 0x58000006]
    GitcoinPass { target: Address, passerby: Address } -> u256,
    #[selector = 0x58000007]
    HatsSetGate { target: Address, gate: Address } -> u256,
    #[selector = 0x58000008]
    HatsPass { target: Address, passerby: Address, hat: u256 } -> u256,
    #[selector = 0x58000009]
    EASSetGate { target: Address, gate: Address } -> u256,
    #[selector = 0x5800000a]
    EASPass { target: Address, passerby: Address, attestation_id: u256 } -> u256,
    #[selector = 0x5800000b]
    SemaphoreSetGate { target: Address, gate: Address } -> u256,
    #[selector = 0x5800000c]
    SemaphorePass {
        target: Address,
        passerby: Address,
        merkle_tree_depth: u256,
        merkle_tree_root: u256,
        nullifier: u256,
        message_value: u256,
        scope: u256,
        points: [u256; 8],
    } -> u256,
    #[selector = 0x5800000d]
    ZKEdDSASetGate { target: Address, gate: Address } -> u256,
    #[selector = 0x5800000e]
    ZKEdDSAPass {
        target: Address,
        passerby: Address,
        p_a: [u256; 2],
        p_b: [[u256; 2]; 2],
        p_c: [u256; 2],
        pub_signals: [u256; 38],
    } -> u256,
}

pub contract ExcubiaCaller uses (call: mut Call) {
    recv ExcubiaCallerMsg {
        FreeForAllSetGate { target, gate } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: FreeForAllExcubiaMsg::SetGate { gate: gate },
            )
        }

        FreeForAllPass { target, passerby } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: FreeForAllExcubiaMsg::Pass { passerby: passerby },
            )
        }

        ERC721SetGate { target, gate } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: ERC721ExcubiaMsg::SetGate { gate: gate },
            )
        }

        ERC721Pass { target, passerby, token_id } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: ERC721ExcubiaMsg::Pass { passerby: passerby, token_id: token_id },
            )
        }

        GitcoinSetGate { target, gate } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: GitcoinPassportExcubiaMsg::SetGate { gate: gate },
            )
        }

        GitcoinPass { target, passerby } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: GitcoinPassportExcubiaMsg::Pass { passerby: passerby },
            )
        }

        HatsSetGate { target, gate } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: HatsExcubiaMsg::SetGate { gate: gate },
            )
        }

        HatsPass { target, passerby, hat } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: HatsExcubiaMsg::Pass { passerby: passerby, hat: hat },
            )
        }

        EASSetGate { target, gate } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: EASExcubiaMsg::SetGate { gate: gate },
            )
        }

        EASPass { target, passerby, attestation_id } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: EASExcubiaMsg::Pass { passerby: passerby, attestation_id: attestation_id },
            )
        }

        SemaphoreSetGate { target, gate } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: SemaphoreExcubiaMsg::SetGate { gate: gate },
            )
        }

        SemaphorePass {
            target,
            passerby,
            merkle_tree_depth,
            merkle_tree_root,
            nullifier,
            message_value,
            scope,
            points,
        } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: SemaphoreExcubiaMsg::Pass {
                    passerby: passerby,
                    merkle_tree_depth: merkle_tree_depth,
                    merkle_tree_root: merkle_tree_root,
                    nullifier: nullifier,
                    message_value: message_value,
                    scope: scope,
                    points: points,
                },
            )
        }

        ZKEdDSASetGate { target, gate } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: gate },
            )
        }

        ZKEdDSAPass { target, passerby, p_a, p_b, p_c, pub_signals } -> u256 uses (mut call) {
            call.call(
                addr: target,
                gas: 5000000,
                value: 0,
                message: ZKEdDSAEventTicketPCDExcubiaMsg::Pass {
                    passerby: passerby,
                    p_a: p_a,
                    p_b: p_b,
                    p_c: p_c,
                    pub_signals: pub_signals,
                },
            )
        }
    }
}

#[test]
fn test_free_for_all_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2000)
    let excubia = evm.create2<FreeForAllExcubia>(value: 0, args: (), salt: 2001)
    let passerby = Address { inner: 0x1001 }

    let trait_value: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: FreeForAllExcubiaMsg::Trait {},
    )
    assert(trait_value == EXCUBIA_TRAIT_FREE_FOR_ALL)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::FreeForAllSetGate { target: excubia, gate: caller },
    )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: FreeForAllExcubiaMsg::SetGate { gate: Address::zero() },
    )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: FreeForAllExcubiaMsg::SetGate { gate: caller },
    )
    assert(err == ExcubiaError::None.code())

    let gate_inner: u256 = evm.call(addr: excubia, gas: 100000, value: 0, message: FreeForAllExcubiaMsg::Gate {})
    assert(gate_inner == caller.inner)

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: FreeForAllExcubiaMsg::SetGate { gate: passerby },
    )
    assert(err == ExcubiaError::GateAlreadySet.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: FreeForAllExcubiaMsg::Check { passerby: passerby },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: FreeForAllExcubiaMsg::HasPassed { passerby: passerby },
    )
    assert(!has_passed)

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: FreeForAllExcubiaMsg::Pass { passerby: passerby },
    )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::FreeForAllPass { target: excubia, passerby: passerby },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: FreeForAllExcubiaMsg::HasPassed { passerby: passerby },
    )
    assert(has_passed)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::FreeForAllPass { target: excubia, passerby: passerby },
    )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test]
fn test_erc721_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2010)
    let nft = evm.create2<MockERC721>(value: 0, args: (), salt: 2011)
    let excubia = evm.create2<ERC721Excubia>(value: 0, args: (nft,), salt: 2012)
    let passerby = Address { inner: 0x2001 }
    let other = Address { inner: 0x2002 }

    evm.call(addr: nft, gas: 100000, value: 0, message: MockERC721Msg::Mint { token_id: 0, owner: passerby })
    evm.call(addr: nft, gas: 100000, value: 0, message: MockERC721Msg::Mint { token_id: 1, owner: other })

    let trait_value: u256 = evm.call(addr: excubia, gas: 100000, value: 0, message: ERC721ExcubiaMsg::Trait {})
    assert(trait_value == EXCUBIA_TRAIT_ERC721)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::ERC721SetGate { target: excubia, gate: caller },
    )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ERC721ExcubiaMsg::SetGate { gate: Address::zero() },
    )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ERC721ExcubiaMsg::SetGate { gate: caller },
    )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ERC721ExcubiaMsg::Check { passerby: passerby, token_id: 1 },
    )
    assert(err == ExcubiaError::UnexpectedTokenOwner.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ERC721ExcubiaMsg::Check { passerby: passerby, token_id: 0 },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ERC721ExcubiaMsg::HasPassedTokenId { token_id: 0 },
    )
    assert(!has_passed)

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ERC721ExcubiaMsg::Pass { passerby: passerby, token_id: 0 },
    )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::ERC721Pass { target: excubia, passerby: passerby, token_id: 1 },
    )
    assert(err == ExcubiaError::UnexpectedTokenOwner.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::ERC721Pass { target: excubia, passerby: passerby, token_id: 0 },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ERC721ExcubiaMsg::HasPassedTokenId { token_id: 0 },
    )
    assert(has_passed)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::ERC721Pass { target: excubia, passerby: passerby, token_id: 0 },
    )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test]
fn test_gitcoin_passport_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2020)
    let decoder = evm.create2<MockGitcoinPassportDecoder>(value: 0, args: (), salt: 2021)
    let excubia = evm.create2<GitcoinPassportExcubia>(value: 0, args: (decoder, 35), salt: 2022)
    let passerby = Address { inner: 0x3001 }
    let low_score = Address { inner: 0x3002 }

    evm.call(
        addr: decoder,
        gas: 100000,
        value: 0,
        message: MockGitcoinPassportDecoderMsg::SetScore { user: passerby, score: 5000 },
    )
    evm.call(
        addr: decoder,
        gas: 100000,
        value: 0,
        message: MockGitcoinPassportDecoderMsg::SetScore { user: low_score, score: 1000 },
    )

    let trait_value: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: GitcoinPassportExcubiaMsg::Trait {},
    )
    assert(trait_value == EXCUBIA_TRAIT_GITCOIN_PASSPORT)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::GitcoinSetGate { target: excubia, gate: caller },
    )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: GitcoinPassportExcubiaMsg::SetGate { gate: Address::zero() },
    )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: GitcoinPassportExcubiaMsg::SetGate { gate: caller },
    )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: GitcoinPassportExcubiaMsg::Check { passerby: low_score },
    )
    assert(err == ExcubiaError::InsufficientScore.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: GitcoinPassportExcubiaMsg::Check { passerby: passerby },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: GitcoinPassportExcubiaMsg::HasPassed { passerby: passerby },
    )
    assert(!has_passed)

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: GitcoinPassportExcubiaMsg::Pass { passerby: passerby },
    )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::GitcoinPass { target: excubia, passerby: low_score },
    )
    assert(err == ExcubiaError::InsufficientScore.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::GitcoinPass { target: excubia, passerby: passerby },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: GitcoinPassportExcubiaMsg::HasPassed { passerby: passerby },
    )
    assert(has_passed)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::GitcoinPass { target: excubia, passerby: passerby },
    )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test]
fn test_hats_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2030)
    let hats = evm.create2<MockHats>(value: 0, args: (), salt: 2031)
    let excubia = evm.create2<HatsExcubia>(value: 0, args: (hats, [1, 0, 0, 0], 1), salt: 2032)
    let passerby = Address { inner: 0x4001 }
    let not_wearer = Address { inner: 0x4002 }

    evm.call(
        addr: hats,
        gas: 100000,
        value: 0,
        message: MockHatsMsg::SetWearer { user: passerby, hat: 1, is_wearer: true },
    )

    let trait_value: u256 = evm.call(addr: excubia, gas: 100000, value: 0, message: HatsExcubiaMsg::Trait {})
    assert(trait_value == EXCUBIA_TRAIT_HATS)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::HatsSetGate { target: excubia, gate: caller },
    )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: HatsExcubiaMsg::SetGate { gate: Address::zero() },
    )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: HatsExcubiaMsg::SetGate { gate: caller },
    )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: HatsExcubiaMsg::Check { passerby: passerby, hat: 2 },
    )
    assert(err == ExcubiaError::NotCriterionHat.code())

    let is_criterion: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: HatsExcubiaMsg::IsCriterionHat { hat: 2 },
    )
    assert(!is_criterion)

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: HatsExcubiaMsg::Check { passerby: not_wearer, hat: 1 },
    )
    assert(err == ExcubiaError::NotWearingCriterionHat.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: HatsExcubiaMsg::Check { passerby: passerby, hat: 1 },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: HatsExcubiaMsg::HasPassed { passerby: passerby },
    )
    assert(!has_passed)

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: HatsExcubiaMsg::Pass { passerby: passerby, hat: 1 },
    )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::HatsPass { target: excubia, passerby: passerby, hat: 2 },
    )
    assert(err == ExcubiaError::NotCriterionHat.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::HatsPass { target: excubia, passerby: not_wearer, hat: 1 },
    )
    assert(err == ExcubiaError::NotWearingCriterionHat.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::HatsPass { target: excubia, passerby: passerby, hat: 1 },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: HatsExcubiaMsg::HasPassed { passerby: passerby },
    )
    assert(has_passed)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::HatsPass { target: excubia, passerby: passerby, hat: 1 },
    )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test]
fn test_eas_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2050)
    let passerby = Address { inner: 0x5001 }
    let attester = Address { inner: 0x5002 }
    let eas = evm.create2<MockEAS>(value: 0, args: (passerby, attester, EAS_SCHEMA_ID), salt: 2051)
    let excubia = evm.create2<EASExcubia>(value: 0, args: (eas, attester, EAS_SCHEMA_ID), salt: 2052)

    let trait_value: u256 = evm.call(addr: excubia, gas: 100000, value: 0, message: EASExcubiaMsg::Trait {})
    assert(trait_value == EXCUBIA_TRAIT_EAS)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::EASSetGate { target: excubia, gate: caller },
    )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: EASExcubiaMsg::SetGate { gate: Address::zero() },
    )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: EASExcubiaMsg::SetGate { gate: caller },
    )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: EASExcubiaMsg::Check { passerby: passerby, attestation_id: 4 },
    )
    assert(err == ExcubiaError::UnexpectedRecipient.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: EASExcubiaMsg::Check { passerby: passerby, attestation_id: 2 },
    )
    assert(err == ExcubiaError::RevokedAttestation.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: EASExcubiaMsg::Check { passerby: passerby, attestation_id: 3 },
    )
    assert(err == ExcubiaError::UnexpectedSchema.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: EASExcubiaMsg::Check { passerby: passerby, attestation_id: 5 },
    )
    assert(err == ExcubiaError::UnexpectedAttester.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: EASExcubiaMsg::Check { passerby: passerby, attestation_id: 1 },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: EASExcubiaMsg::HasPassedAttestation { attestation_id: 1 },
    )
    assert(!has_passed)

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: EASExcubiaMsg::Pass { passerby: passerby, attestation_id: 1 },
    )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::EASPass { target: excubia, passerby: passerby, attestation_id: 4 },
    )
    assert(err == ExcubiaError::UnexpectedRecipient.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::EASPass { target: excubia, passerby: passerby, attestation_id: 2 },
    )
    assert(err == ExcubiaError::RevokedAttestation.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::EASPass { target: excubia, passerby: passerby, attestation_id: 3 },
    )
    assert(err == ExcubiaError::UnexpectedSchema.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::EASPass { target: excubia, passerby: passerby, attestation_id: 5 },
    )
    assert(err == ExcubiaError::UnexpectedAttester.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::EASPass { target: excubia, passerby: passerby, attestation_id: 1 },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: EASExcubiaMsg::HasPassedAttestation { attestation_id: 1 },
    )
    assert(has_passed)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::EASPass { target: excubia, passerby: passerby, attestation_id: 1 },
    )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test]
fn test_semaphore_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2060)
    let semaphore = evm.create2<MockSemaphore>(value: 0, args: (), salt: 2061)
    let excubia = evm.create2<SemaphoreExcubia>(value: 0, args: (semaphore, 0), salt: 2062)
    let passerby = Address { inner: 0x6001 }

    let trait_value: u256 = evm.call(addr: excubia, gas: 100000, value: 0, message: SemaphoreExcubiaMsg::Trait {})
    assert(trait_value == EXCUBIA_TRAIT_SEMAPHORE)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::SemaphoreSetGate { target: excubia, gate: caller },
    )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: SemaphoreExcubiaMsg::SetGate { gate: Address::zero() },
    )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: SemaphoreExcubiaMsg::SetGate { gate: caller },
    )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: SemaphoreExcubiaMsg::Check {
            passerby: passerby,
            merkle_tree_depth: 1,
            merkle_tree_root: 0,
            nullifier: 0,
            message_value: 0,
            scope: 1,
            points: [0, 0, 0, 0, 0, 0, 0, 0],
        },
    )
    assert(err == ExcubiaError::UnexpectedScope.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: SemaphoreExcubiaMsg::Check {
            passerby: passerby,
            merkle_tree_depth: 1,
            merkle_tree_root: 0,
            nullifier: 1,
            message_value: 0,
            scope: 0,
            points: [1, 0, 0, 0, 0, 0, 0, 0],
        },
    )
    assert(err == ExcubiaError::InvalidProof.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: SemaphoreExcubiaMsg::Check {
            passerby: passerby,
            merkle_tree_depth: 1,
            merkle_tree_root: 0,
            nullifier: 0,
            message_value: 0,
            scope: 0,
            points: [0, 0, 0, 0, 0, 0, 0, 0],
        },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: SemaphoreExcubiaMsg::HasPassedNullifier { nullifier: 0 },
    )
    assert(!has_passed)

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: SemaphoreExcubiaMsg::Pass {
            passerby: passerby,
            merkle_tree_depth: 1,
            merkle_tree_root: 0,
            nullifier: 0,
            message_value: 0,
            scope: 0,
            points: [0, 0, 0, 0, 0, 0, 0, 0],
        },
    )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::SemaphorePass {
            target: excubia,
            passerby: passerby,
            merkle_tree_depth: 1,
            merkle_tree_root: 0,
            nullifier: 0,
            message_value: 0,
            scope: 1,
            points: [0, 0, 0, 0, 0, 0, 0, 0],
        },
    )
    assert(err == ExcubiaError::UnexpectedScope.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::SemaphorePass {
            target: excubia,
            passerby: passerby,
            merkle_tree_depth: 1,
            merkle_tree_root: 0,
            nullifier: 1,
            message_value: 0,
            scope: 0,
            points: [1, 0, 0, 0, 0, 0, 0, 0],
        },
    )
    assert(err == ExcubiaError::InvalidProof.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::SemaphorePass {
            target: excubia,
            passerby: passerby,
            merkle_tree_depth: 1,
            merkle_tree_root: 0,
            nullifier: 0,
            message_value: 0,
            scope: 0,
            points: [0, 0, 0, 0, 0, 0, 0, 0],
        },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: SemaphoreExcubiaMsg::HasPassedNullifier { nullifier: 0 },
    )
    assert(has_passed)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::SemaphorePass {
            target: excubia,
            passerby: passerby,
            merkle_tree_depth: 1,
            merkle_tree_root: 0,
            nullifier: 0,
            message_value: 0,
            scope: 0,
            points: [0, 0, 0, 0, 0, 0, 0, 0],
        },
    )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test]
fn test_zkeddsa_event_ticket_pcd_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2070)
    let verifier = evm.create2<ZKEdDSAEventTicketPCDVerifier>(value: 0, args: (), salt: 2071)
    let excubia = evm.create2<ZKEdDSAEventTicketPCDExcubia>(
        value: 0,
        args: (verifier, ZKEDDSA_VALID_EVENT_ID, ZKEDDSA_VALID_SIGNER_0, ZKEDDSA_VALID_SIGNER_1),
        salt: 2072,
    )
    let invalid_signer_0_excubia = evm.create2<ZKEdDSAEventTicketPCDExcubia>(
        value: 0,
        args: (verifier, ZKEDDSA_VALID_EVENT_ID, ZKEDDSA_INVALID_SIGNER_0, ZKEDDSA_VALID_SIGNER_1),
        salt: 2073,
    )
    let invalid_signer_1_excubia = evm.create2<ZKEdDSAEventTicketPCDExcubia>(
        value: 0,
        args: (verifier, ZKEDDSA_VALID_EVENT_ID, ZKEDDSA_VALID_SIGNER_0, ZKEDDSA_INVALID_SIGNER_1),
        salt: 2074,
    )
    let invalid_event_id_excubia = evm.create2<ZKEdDSAEventTicketPCDExcubia>(
        value: 0,
        args: (verifier, ZKEDDSA_INVALID_EVENT_ID, ZKEDDSA_VALID_SIGNER_0, ZKEDDSA_VALID_SIGNER_1),
        salt: 2075,
    )
    let passerby = Address { inner: 0x627306090abab3a6e1400e9345bc60c78a8bef57 }

    let trait_value: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::Trait {},
    )
    assert(trait_value == EXCUBIA_TRAIT_ZKEDDSA_EVENT_TICKET_PCD)

    let verifier_ok: bool = evm.call(
        addr: verifier,
        gas: 5000000,
        value: 0,
        message: ZKEdDSAEventTicketPCDVerifierMsg::VerifyProof {
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(verifier_ok)

    let verifier_ok: bool = evm.call(
        addr: verifier,
        gas: 5000000,
        value: 0,
        message: ZKEdDSAEventTicketPCDVerifierMsg::VerifyProof {
            p_a: ZKEDDSA_INVALID_PROOF_A,
            p_b: ZKEDDSA_INVALID_PROOF_B,
            p_c: ZKEDDSA_INVALID_PROOF_C,
            pub_signals: ZKEDDSA_INVALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(!verifier_ok)

    let err: u256 = evm.call(
        addr: caller,
        gas: 200000,
        value: 0,
        message: ExcubiaCallerMsg::ZKEdDSASetGate { target: excubia, gate: caller },
    )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: Address::zero() },
    )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: caller },
    )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm.call(
        addr: invalid_signer_0_excubia,
        gas: 100000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: caller },
    )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm.call(
        addr: invalid_signer_1_excubia,
        gas: 100000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: caller },
    )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm.call(
        addr: invalid_event_id_excubia,
        gas: 100000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: caller },
    )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm.call(
        addr: invalid_signer_0_excubia,
        gas: 5000000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
            passerby: passerby,
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::InvalidSigners.code())

    let err: u256 = evm.call(
        addr: invalid_signer_1_excubia,
        gas: 5000000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
            passerby: passerby,
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::InvalidSigners.code())

    let err: u256 = evm.call(
        addr: invalid_event_id_excubia,
        gas: 5000000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
            passerby: passerby,
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::InvalidEventId.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 5000000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
            passerby: passerby,
            p_a: ZKEDDSA_INVALIDWATERMARK_PROOF_A,
            p_b: ZKEDDSA_INVALIDWATERMARK_PROOF_B,
            p_c: ZKEDDSA_INVALIDWATERMARK_PROOF_C,
            pub_signals: ZKEDDSA_INVALIDWATERMARK_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::InvalidWatermark.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 5000000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
            passerby: passerby,
            p_a: ZKEDDSA_INVALID_PROOF_A,
            p_b: ZKEDDSA_INVALID_PROOF_B,
            p_c: ZKEDDSA_INVALID_PROOF_C,
            pub_signals: ZKEDDSA_INVALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::InvalidProof.code())

    let err: u256 = evm.call(
        addr: excubia,
        gas: 5000000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
            passerby: passerby,
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::HasPassedZKEdDSAEventTicketPCD {
            ticket_id: ZKEDDSA_VALID_TICKET_ID,
        },
    )
    assert(!has_passed)

    let err: u256 = evm.call(
        addr: excubia,
        gas: 5000000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::Pass {
            passerby: passerby,
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 5000000,
        value: 0,
        message: ExcubiaCallerMsg::ZKEdDSAPass {
            target: invalid_signer_0_excubia,
            passerby: passerby,
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::InvalidSigners.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 5000000,
        value: 0,
        message: ExcubiaCallerMsg::ZKEdDSAPass {
            target: invalid_signer_1_excubia,
            passerby: passerby,
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::InvalidSigners.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 5000000,
        value: 0,
        message: ExcubiaCallerMsg::ZKEdDSAPass {
            target: invalid_event_id_excubia,
            passerby: passerby,
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::InvalidEventId.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 5000000,
        value: 0,
        message: ExcubiaCallerMsg::ZKEdDSAPass {
            target: excubia,
            passerby: passerby,
            p_a: ZKEDDSA_INVALIDWATERMARK_PROOF_A,
            p_b: ZKEDDSA_INVALIDWATERMARK_PROOF_B,
            p_c: ZKEDDSA_INVALIDWATERMARK_PROOF_C,
            pub_signals: ZKEDDSA_INVALIDWATERMARK_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::InvalidWatermark.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 5000000,
        value: 0,
        message: ExcubiaCallerMsg::ZKEdDSAPass {
            target: excubia,
            passerby: passerby,
            p_a: ZKEDDSA_INVALID_PROOF_A,
            p_b: ZKEDDSA_INVALID_PROOF_B,
            p_c: ZKEDDSA_INVALID_PROOF_C,
            pub_signals: ZKEDDSA_INVALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::InvalidProof.code())

    let err: u256 = evm.call(
        addr: caller,
        gas: 5000000,
        value: 0,
        message: ExcubiaCallerMsg::ZKEdDSAPass {
            target: excubia,
            passerby: passerby,
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm.call(
        addr: excubia,
        gas: 100000,
        value: 0,
        message: ZKEdDSAEventTicketPCDExcubiaMsg::HasPassedZKEdDSAEventTicketPCD {
            ticket_id: ZKEDDSA_VALID_TICKET_ID,
        },
    )
    assert(has_passed)

    let err: u256 = evm.call(
        addr: caller,
        gas: 5000000,
        value: 0,
        message: ExcubiaCallerMsg::ZKEdDSAPass {
            target: excubia,
            passerby: passerby,
            p_a: ZKEDDSA_VALID_PROOF_A,
            p_b: ZKEDDSA_VALID_PROOF_B,
            p_c: ZKEDDSA_VALID_PROOF_C,
            pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
        },
    )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test(should_revert)]
fn test_zkeddsa_event_ticket_pcd_excubia_rejects_zero_verifier() uses (evm: mut Evm) {
    let _ = evm.create2<ZKEdDSAEventTicketPCDExcubia>(
        value: 0,
        args: (Address::zero(), ZKEDDSA_VALID_EVENT_ID, ZKEDDSA_VALID_SIGNER_0, ZKEDDSA_VALID_SIGNER_1),
        salt: 2076,
    )
}

