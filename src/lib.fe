    if round == 67 {
        return (
            0x29a322a84c25bd2ddf6e2e4200228d95abd6349a02266ac1dbba520738ceca97,
            0x678c9bfc6f2df012f4fe55e33bb68ac14ced1df0d02152792089d046d828c43,
            0xfaff3a5e7425794fe20a7e0eb615b8b1760394b7f2304286a3ae4009124db23,
            0x1f8f5b611af9feb9cea86c084058120553e404103aee213f5a41d1d02541c0d3,
            0x160875d8479602f96f40acc2d042ee52c1588b6a29de4284965a6dc6c930ea07,
            0x16d87a5183a316a1d70afc951efe2cd667c77328fcfda458cbf5fe3045f46d9e,
        )
    }

    (0, 0, 0, 0, 0, 0)
}
fn hash5(a: u256, b: u256, c: u256, d: u256, e: u256) -> u256 {
    let mut s0: u256 = 0
    let mut s1: u256 = a
    let mut s2: u256 = b
    let mut s3: u256 = c
    let mut s4: u256 = d
    let mut s5: u256 = e

    let mut round: usize = 0
    while round < POSEIDON_T6_ROUNDS {
        let (c0, c1, c2, c3, c4, c5) = poseidon_t6_round_constants(round)

        s0 = field_add(s0, c0)
        s1 = field_add(s1, c1)
        s2 = field_add(s2, c2)
        s3 = field_add(s3, c3)
        s4 = field_add(s4, c4)
        s5 = field_add(s5, c5)

        if round < POSEIDON_T6_HALF_FULL_ROUNDS
            || round >= POSEIDON_T6_HALF_FULL_ROUNDS + POSEIDON_T6_PARTIAL_ROUNDS {
            s0 = poseidon_exp5(s0)
            s1 = poseidon_exp5(s1)
            s2 = poseidon_exp5(s2)
            s3 = poseidon_exp5(s3)
            s4 = poseidon_exp5(s4)
            s5 = poseidon_exp5(s5)
        } else {
            s0 = poseidon_exp5(s0)
        }

        let n0 = field_add(
            field_add(
                field_add(
                    field_add(
                        field_add(
                            field_mul(POSEIDON_T6_M00, s0),
                            field_mul(POSEIDON_T6_M10, s1),
                        ),
                        field_mul(POSEIDON_T6_M20, s2),
                    ),
                    field_mul(POSEIDON_T6_M30, s3),
                ),
                field_mul(POSEIDON_T6_M40, s4),
            ),
            field_mul(POSEIDON_T6_M50, s5),
        )
        let n1 = field_add(
            field_add(
                field_add(
                    field_add(
                        field_add(
                            field_mul(POSEIDON_T6_M01, s0),
                            field_mul(POSEIDON_T6_M11, s1),
                        ),
                        field_mul(POSEIDON_T6_M21, s2),
                    ),
                    field_mul(POSEIDON_T6_M31, s3),
                ),
                field_mul(POSEIDON_T6_M41, s4),
            ),
            field_mul(POSEIDON_T6_M51, s5),
        )
        let n2 = field_add(
            field_add(
                field_add(
                    field_add(
                        field_add(
                            field_mul(POSEIDON_T6_M02, s0),
                            field_mul(POSEIDON_T6_M12, s1),
                        ),
                        field_mul(POSEIDON_T6_M22, s2),
                    ),
                    field_mul(POSEIDON_T6_M32, s3),
                ),
                field_mul(POSEIDON_T6_M42, s4),
            ),
            field_mul(POSEIDON_T6_M52, s5),
        )
        let n3 = field_add(
            field_add(
                field_add(
                    field_add(
                        field_add(
                            field_mul(POSEIDON_T6_M03, s0),
                            field_mul(POSEIDON_T6_M13, s1),
                        ),
                        field_mul(POSEIDON_T6_M23, s2),
                    ),
                    field_mul(POSEIDON_T6_M33, s3),
                ),
                field_mul(POSEIDON_T6_M43, s4),
            ),
            field_mul(POSEIDON_T6_M53, s5),
        )
        let n4 = field_add(
            field_add(
                field_add(
                    field_add(
                        field_add(
                            field_mul(POSEIDON_T6_M04, s0),
                            field_mul(POSEIDON_T6_M14, s1),
                        ),
                        field_mul(POSEIDON_T6_M24, s2),
                    ),
                    field_mul(POSEIDON_T6_M34, s3),
                ),
                field_mul(POSEIDON_T6_M44, s4),
            ),
            field_mul(POSEIDON_T6_M54, s5),
        )
        let n5 = field_add(
            field_add(
                field_add(
                    field_add(
                        field_add(
                            field_mul(POSEIDON_T6_M05, s0),
                            field_mul(POSEIDON_T6_M15, s1),
                        ),
                        field_mul(POSEIDON_T6_M25, s2),
                    ),
                    field_mul(POSEIDON_T6_M35, s3),
                ),
                field_mul(POSEIDON_T6_M45, s4),
            ),
            field_mul(POSEIDON_T6_M55, s5),
        )

        s0 = n0
        s1 = n1
        s2 = n2
        s3 = n3
        s4 = n4
        s5 = n5
        round += 1
    }

    s0
}

pub enum IMTError {
    None,
    DepthNotSupported,
    ValueGreaterThanSnarkScalarField,
    WrongMerkleProofPath,
    TreeIsFull,
    NewLeafCannotEqualOldLeaf,
    LeafDoesNotExist,
    LeafIndexOutOfRange,
}

impl IMTError {
    pub fn is_none(self) -> bool {
        match self {
            IMTError::None => true,
            _ => false,
        }
    }
    pub fn code(self) -> u256 {
        match self {
            IMTError::None => 0,
            IMTError::DepthNotSupported => 1,
            IMTError::ValueGreaterThanSnarkScalarField => 2,
            IMTError::WrongMerkleProofPath => 3,
            IMTError::TreeIsFull => 4,
            IMTError::NewLeafCannotEqualOldLeaf => 5,
            IMTError::LeafDoesNotExist => 6,
            IMTError::LeafIndexOutOfRange => 7,
        }
    }
}

pub struct IMT { pub depth: usize, pub root: u256 }

impl Copy for IMT {}

fn field_add(lhs: u256, rhs: u256) -> u256 {
    addmod(lhs, rhs, SNARK_SCALAR_FIELD)
}

fn field_mul(lhs: u256, rhs: u256) -> u256 {
    mulmod(lhs, rhs, SNARK_SCALAR_FIELD)
}

fn poseidon_exp5(x: u256) -> u256 {
    let x2 = field_mul(x, x)
    let x4 = field_mul(x2, x2)
    field_mul(x4, x)
}

fn poseidon_t3_mix(state: [u256; 3]) -> [u256; 3] {
    let s0 = state[0]
    let s1 = state[1]
    let s2 = state[2]

    let mut mixed: [u256; 3] = [0; 3]

    let m00 = field_mul(POSEIDON_T3_M00, s0)
    let m01 = field_mul(POSEIDON_T3_M01, s1)
    let m02 = field_mul(POSEIDON_T3_M02, s2)
    mixed[0] = field_add(field_add(m00, m01), m02)

    let m10 = field_mul(POSEIDON_T3_M10, s0)
    let m11 = field_mul(POSEIDON_T3_M11, s1)
    let m12 = field_mul(POSEIDON_T3_M12, s2)
    mixed[1] = field_add(field_add(m10, m11), m12)

    let m20 = field_mul(POSEIDON_T3_M20, s0)
    let m21 = field_mul(POSEIDON_T3_M21, s1)
    let m22 = field_mul(POSEIDON_T3_M22, s2)
    mixed[2] = field_add(field_add(m20, m21), m22)

    mixed
}

fn hash2(left: u256, right: u256) -> u256 {
    let mut state: [u256; 3] = [0; 3]
    state[1] = left
    state[2] = right

    let mut round: usize = 0

    while round < POSEIDON_T3_ROUNDS {
        let round_constants = poseidon_t3_round_constants(round)

        state[0] = field_add(state[0], round_constants[0])
        state[1] = field_add(state[1], round_constants[1])
        state[2] = field_add(state[2], round_constants[2])

        if round < POSEIDON_T3_HALF_FULL_ROUNDS
            || round >= POSEIDON_T3_HALF_FULL_ROUNDS + POSEIDON_T3_PARTIAL_ROUNDS {
            state[0] = poseidon_exp5(state[0])
            state[1] = poseidon_exp5(state[1])
            state[2] = poseidon_exp5(state[2])
        } else {
            state[0] = poseidon_exp5(state[0])
        }

        state = poseidon_t3_mix(state)
        round += 1
    }

    state[0]
}

impl IMT {
    pub fn new(depth: usize, root: u256) -> Self {
        assert(depth > 0 && depth <= MAX_DEPTH)
        IMT { depth: depth, root: root }
    }
    pub fn calculate_root(
        self,
        leaf: u256,
        proof_depth: usize,
        indices: [u8; MAX_DEPTH],
        siblings: [u256; MAX_DEPTH],
    ) -> u256 {
        let mut node = leaf
        let mut i: usize = 0

        while i < MAX_DEPTH {
            if i < proof_depth {
                if indices[i] == 0 {
                    node = hash2(node, siblings[i])
                } else {
                    node = hash2(siblings[i], node)
                }
            }

            i += 1
        }

        node
    }
    pub fn verify(
        self,
        leaf: u256,
        proof_depth: usize,
        indices: [u8; MAX_DEPTH],
        siblings: [u256; MAX_DEPTH],
    ) -> bool {
        let (ok, err) = self.verify_checked(leaf, proof_depth, indices, siblings)
        if err.is_none() { ok } else { false }
    }
    pub fn verify_checked(
        self,
        leaf: u256,
        proof_depth: usize,
        indices: [u8; MAX_DEPTH],
        siblings: [u256; MAX_DEPTH],
    ) -> (bool, IMTError) {
        if self.depth == 0 || self.depth > MAX_DEPTH {
            return (false, IMTError::DepthNotSupported)
        }

        if proof_depth != self.depth {
            return (false, IMTError::WrongMerkleProofPath)
        }

        if leaf >= SNARK_SCALAR_FIELD {
            return (false, IMTError::ValueGreaterThanSnarkScalarField)
        }

        let mut node = leaf
        let mut i: usize = 0

        while i < proof_depth {
            if siblings[i] >= SNARK_SCALAR_FIELD {
                return (false, IMTError::ValueGreaterThanSnarkScalarField)
            }

            if indices[i] != 0 && indices[i] != 1 {
                return (false, IMTError::WrongMerkleProofPath)
            }

            if indices[i] == 0 {
                node = hash2(node, siblings[i])
            } else {
                node = hash2(siblings[i], node)
            }

            i += 1
        }

        (node == self.root, IMTError::None)
    }
}

pub struct Subtree { pub left: u256, pub right: u256 }

impl Copy for Subtree {}

pub struct BinaryIMTData {
    pub depth: usize,
    pub root: u256,
    pub number_of_leaves: usize,
    pub zeroes: [u256; MAX_DEPTH],
    pub last_subtrees: [Subtree; MAX_DEPTH],
    pub use_default_zeroes: bool,
}

impl BinaryIMTData {
    pub fn empty() -> Self {
        BinaryIMTData {
            depth: 0,
            root: 0,
            number_of_leaves: 0,
            zeroes: [0; MAX_DEPTH],
            last_subtrees: [Subtree { left: 0, right: 0 }; MAX_DEPTH],
            use_default_zeroes: false,
        }
    }
    pub fn default_zero(index: usize) -> u256 {
        assert(index <= MAX_DEPTH)

        let mut z: u256 = 0
        let mut i: usize = 0

        while i < index {
            z = hash2(z, z)
            i += 1
        }

        z
    }
    pub fn init(mut self, depth: usize, zero: u256) -> IMTError {
        if zero >= SNARK_SCALAR_FIELD {
            return IMTError::ValueGreaterThanSnarkScalarField
        }

        if depth == 0 || depth > MAX_DEPTH {
            return IMTError::DepthNotSupported
        }

        self.depth = depth
        self.root = 0
        self.number_of_leaves = 0
        self.use_default_zeroes = false
        self.zeroes = [0; MAX_DEPTH]
        self.last_subtrees = [Subtree { left: 0, right: 0 }; MAX_DEPTH]

        let mut current_zero = zero
        let mut i: usize = 0

        while i < depth {
            self.zeroes[i] = current_zero
            current_zero = hash2(current_zero, current_zero)
            i += 1
        }

        self.root = current_zero

        IMTError::None
    }
    pub fn init_with_default_zeroes(mut self, depth: usize) -> IMTError {
        if depth == 0 || depth > MAX_DEPTH {
            return IMTError::DepthNotSupported
        }

        self.depth = depth
        self.root = BinaryIMTData::default_zero(depth)
        self.number_of_leaves = 0
        self.use_default_zeroes = true
        self.zeroes = [0; MAX_DEPTH]
        self.last_subtrees = [Subtree { left: 0, right: 0 }; MAX_DEPTH]

        IMTError::None
    }

    fn zero_at(self, level: usize) -> u256 {
        if self.use_default_zeroes {
            BinaryIMTData::default_zero(level)
        } else {
            self.zeroes[level]
        }
    }
    pub fn insert(mut self, leaf: u256) -> (u256, IMTError) {
        if self.depth == 0 || self.depth > MAX_DEPTH {
            return (0, IMTError::DepthNotSupported)
        }

        if leaf >= SNARK_SCALAR_FIELD {
            return (0, IMTError::ValueGreaterThanSnarkScalarField)
        }

        let capacity: usize = 1 << self.depth
        if self.number_of_leaves >= capacity {
            return (0, IMTError::TreeIsFull)
        }

        let mut index = self.number_of_leaves
        let mut h = leaf
        let mut i: usize = 0

        while i < self.depth {
            if index & 1 == 0 {
                self.last_subtrees[i].left = h
                self.last_subtrees[i].right = self.zero_at(i)
            } else {
                self.last_subtrees[i].right = h
            }

            h = hash2(self.last_subtrees[i].left, self.last_subtrees[i].right)
            index = index >> 1
            i += 1
        }

        self.root = h
        self.number_of_leaves += 1

        (h, IMTError::None)
    }
    pub fn verify(self, leaf: u256, siblings: [u256; MAX_DEPTH], indices: [u8; MAX_DEPTH]) -> (
        bool,
        IMTError,
    ) {
        let imt = IMT { depth: self.depth, root: self.root }
        imt.verify_checked(leaf, self.depth, indices, siblings)
    }
    pub fn update(
        mut self,
        leaf: u256,
        new_leaf: u256,
        siblings: [u256; MAX_DEPTH],
        indices: [u8; MAX_DEPTH],
    ) -> IMTError {
        if new_leaf == leaf {
            return IMTError::NewLeafCannotEqualOldLeaf
        }

        if new_leaf >= SNARK_SCALAR_FIELD {
            return IMTError::ValueGreaterThanSnarkScalarField
        }

        let (ok, err) = self.verify(leaf, siblings, indices)
        if !err.is_none() {
            return err
        }

        if !ok {
            return IMTError::LeafDoesNotExist
        }

        let mut h = new_leaf
        let mut update_index: usize = 0
        let mut i: usize = 0

        while i < self.depth {
            let path = indices[i]
            update_index = update_index | ((path as usize) << i)

            if path == 0 {
                if siblings[i] == self.last_subtrees[i].right {
                    self.last_subtrees[i].left = h
                }

                h = hash2(h, siblings[i])
            } else {
                if siblings[i] == self.last_subtrees[i].left {
                    self.last_subtrees[i].right = h
                }

                h = hash2(siblings[i], h)
            }

            i += 1
        }

        if update_index >= self.number_of_leaves {
            return IMTError::LeafIndexOutOfRange
        }

        self.root = h

        IMTError::None
    }
    pub fn remove(
        mut self,
        leaf: u256,
        siblings: [u256; MAX_DEPTH],
        indices: [u8; MAX_DEPTH],
    ) -> IMTError {
        let replacement = if self.use_default_zeroes {
            0
        } else {
            self.zeroes[0]
        }

        self.update(leaf, replacement, siblings, indices)
    }
}

fn depth2_root(l0: u256, l1: u256, l2: u256, l3: u256) -> u256 {
    hash2(hash2(l0, l1), hash2(l2, l3))
}

#[test]
fn test_verify_depth_1_happy_path() {
    let mut indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    let mut siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    siblings[0] = 11

    let leaf: u256 = 7
    let root = hash2(leaf, siblings[0])
    let imt = IMT::new(1, root)

    let ok = imt.verify(leaf, 1, indices, siblings)
    assert(ok)
}

#[test]
fn test_verify_depth_4_happy_path() {
    let mut indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    indices[1] = 1
    indices[3] = 1

    let mut siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    siblings[0] = 11
    siblings[1] = 13
    siblings[2] = 17
    siblings[3] = 19

    let leaf: u256 = 7
    let root = hash2(19, hash2(hash2(13, hash2(leaf, 11)), 17))

    let imt = IMT::new(4, root)
    let ok = imt.verify(leaf, 4, indices, siblings)
    assert(ok)
}

#[test]
fn test_verify_depth_32_boundary_happy_path() {
    let mut indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    let siblings: [u256; MAX_DEPTH] = [1; MAX_DEPTH]

    let leaf: u256 = 5
    let temp = IMT::new(32, 0)
    let root = temp.calculate_root(leaf, 32, indices, siblings)
    let imt = IMT::new(32, root)

    let (ok, err) = imt.verify_checked(leaf, 32, indices, siblings)
    assert(ok)
    assert(err.code() == 0)
}

#[test]
fn test_wrong_proof_returns_false() {
    let mut indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    indices[1] = 1
    indices[3] = 1

    let mut good_siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    good_siblings[0] = 11
    good_siblings[1] = 13
    good_siblings[2] = 17
    good_siblings[3] = 19

    let mut bad_siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    bad_siblings[0] = 12
    bad_siblings[1] = 13
    bad_siblings[2] = 17
    bad_siblings[3] = 19

    let leaf: u256 = 7
    let root = hash2(19, hash2(hash2(13, hash2(leaf, 11)), 17))

    let imt = IMT::new(4, root)
    let ok_good = imt.verify(leaf, 4, indices, good_siblings)
    let ok_bad = imt.verify(leaf, 4, indices, bad_siblings)
    let (checked_bad, err) = imt.verify_checked(leaf, 4, indices, bad_siblings)

    assert(ok_good)
    assert(!ok_bad)
    assert(!checked_bad)
    assert(err.code() == 0)
}

#[test]
fn test_depth_mismatch_error() {
    let mut indices: [u8; MAX_DEPTH] = [0; MAX_DEPTH]
    let mut siblings: [u256; MAX_DEPTH] = [0; MAX_DEPTH]
    siblings[0] = 11
    siblings[1] = 13
    siblings[2] = 17
    siblings[3] = 19

    let imt = IMT::new(4, 0)
    let (_ok, err) = imt.verify_checked(7, 3, indices, siblings)
    assert(err.code() == 3)
}

