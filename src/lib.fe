fn poseidon_t3_round_constants(round: usize) -> [u256; 3] {
    assert(round < POSEIDON_T3_ROUNDS)

    if round < 5 {
        let base = (round) * 3
        return [
            POSEIDON_T3_C_CHUNK_0[base],
            POSEIDON_T3_C_CHUNK_0[base + 1],
            POSEIDON_T3_C_CHUNK_0[base + 2],
        ]
    }
    if round < 10 {
        let base = (round - 5) * 3
        return [
            POSEIDON_T3_C_CHUNK_1[base],
            POSEIDON_T3_C_CHUNK_1[base + 1],
            POSEIDON_T3_C_CHUNK_1[base + 2],
        ]
    }
    if round < 15 {
        let base = (round - 10) * 3
        return [
            POSEIDON_T3_C_CHUNK_2[base],
            POSEIDON_T3_C_CHUNK_2[base + 1],
            POSEIDON_T3_C_CHUNK_2[base + 2],
        ]
    }
    if round < 20 {
        let base = (round - 15) * 3
        return [
            POSEIDON_T3_C_CHUNK_3[base],
            POSEIDON_T3_C_CHUNK_3[base + 1],
            POSEIDON_T3_C_CHUNK_3[base + 2],
        ]
    }
    if round < 25 {
        let base = (round - 20) * 3
        return [
            POSEIDON_T3_C_CHUNK_4[base],
            POSEIDON_T3_C_CHUNK_4[base + 1],
            POSEIDON_T3_C_CHUNK_4[base + 2],
        ]
    }
    if round < 30 {
        let base = (round - 25) * 3
        return [
            POSEIDON_T3_C_CHUNK_5[base],
            POSEIDON_T3_C_CHUNK_5[base + 1],
            POSEIDON_T3_C_CHUNK_5[base + 2],
        ]
    }
    if round < 35 {
        let base = (round - 30) * 3
        return [
            POSEIDON_T3_C_CHUNK_6[base],
            POSEIDON_T3_C_CHUNK_6[base + 1],
            POSEIDON_T3_C_CHUNK_6[base + 2],
        ]
    }
    if round < 40 {
        let base = (round - 35) * 3
        return [
            POSEIDON_T3_C_CHUNK_7[base],
            POSEIDON_T3_C_CHUNK_7[base + 1],
            POSEIDON_T3_C_CHUNK_7[base + 2],
        ]
    }
    if round < 45 {
        let base = (round - 40) * 3
        return [
            POSEIDON_T3_C_CHUNK_8[base],
            POSEIDON_T3_C_CHUNK_8[base + 1],
            POSEIDON_T3_C_CHUNK_8[base + 2],
        ]
    }
    if round < 50 {
        let base = (round - 45) * 3
        return [
            POSEIDON_T3_C_CHUNK_9[base],
            POSEIDON_T3_C_CHUNK_9[base + 1],
            POSEIDON_T3_C_CHUNK_9[base + 2],
        ]
    }
    if round < 55 {
        let base = (round - 50) * 3
        return [
            POSEIDON_T3_C_CHUNK_10[base],
            POSEIDON_T3_C_CHUNK_10[base + 1],
            POSEIDON_T3_C_CHUNK_10[base + 2],
        ]
    }
    if round < 60 {
        let base = (round - 55) * 3
        return [
            POSEIDON_T3_C_CHUNK_11[base],
            POSEIDON_T3_C_CHUNK_11[base + 1],
            POSEIDON_T3_C_CHUNK_11[base + 2],
        ]
    }
    if round < 65 {
        let base = (round - 60) * 3
        return [
            POSEIDON_T3_C_CHUNK_12[base],
            POSEIDON_T3_C_CHUNK_12[base + 1],
            POSEIDON_T3_C_CHUNK_12[base + 2],
        ]
    }

    [0; 3]
}

