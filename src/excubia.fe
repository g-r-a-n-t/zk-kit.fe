    attester: Address,
    passed_attestations: StorageMap<u256, bool>,
}

pub contract EASExcubia uses (ctx: Ctx, call: mut Call, log: mut Log) {
    mut store: EASExcubiaStore,

    init(eas: Address, attester: Address, schema: u256)
    uses (mut store, ctx)
    {
        assert(eas != Address::zero())
        assert(attester != Address::zero())
        store.owner = ctx.caller()
        store.gate = Address::zero()
        store.eas = eas
        store.schema = schema
        store.attester = attester
    }

    recv EASExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(
                owner: store.owner,
                gate: store.gate,
                caller: ctx.caller(),
                new_gate: gate,
            )
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check { passerby, attestation_id } -> u256
        uses (store, mut call)
        {
            eas_attestation_err(
                eas: store.eas,
                attestation_id: attestation_id,
                schema: store.schema,
                attester: store.attester,
                passerby: passerby,
            )
                .code()
        }

        Pass { passerby, attestation_id } -> u256
        uses (mut store, ctx, mut call, mut log)
        {
            let err = excubia_pass_common_err(
                gate: store.gate,
                caller: ctx.caller(),
                already_passed: store.passed_attestations.get(key: attestation_id),
            )
            if !err.is_none() {
                return err.code()
            }

            let err = eas_attestation_err(
                eas: store.eas,
                attestation_id: attestation_id,
                schema: store.schema,
                attester: store.attester,
                passerby: passerby,
            )
            if !err.is_none() {
                return err.code()
            }

            store.passed_attestations.set(key: attestation_id, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_EAS
        }

        HasPassedAttestation { attestation_id } -> bool
        uses (store)
        {
            store.passed_attestations.get(key: attestation_id)
        }
    }
}

