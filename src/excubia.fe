                value: 0,
                message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: gate },
            )
        }

        ZKEdDSAPass { target, passerby, p_a, p_b, p_c, pub_signals } -> u256
        uses (mut call)
        {
            call.call(
                addr: target,
                gas: 5000000,
                value: 0,
                message: ZKEdDSAEventTicketPCDExcubiaMsg::Pass {
                    passerby: passerby,
                    p_a: p_a,
                    p_b: p_b,
                    p_c: p_c,
                    pub_signals: pub_signals,
                },
            )
        }
    }
}

#[test]
fn test_free_for_all_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2000)
    let excubia = evm.create2<FreeForAllExcubia>(value: 0, args: (), salt: 2001)
    let passerby = Address { inner: 0x1001 }

    let trait_value: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: FreeForAllExcubiaMsg::Trait {},
        )
    assert(trait_value == EXCUBIA_TRAIT_FREE_FOR_ALL)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::FreeForAllSetGate { target: excubia, gate: caller },
        )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: FreeForAllExcubiaMsg::SetGate { gate: Address::zero() },
        )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: FreeForAllExcubiaMsg::SetGate { gate: caller },
        )
    assert(err == ExcubiaError::None.code())

    let gate_inner: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: FreeForAllExcubiaMsg::Gate {},
        )
    assert(gate_inner == caller.inner)

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: FreeForAllExcubiaMsg::SetGate { gate: passerby },
        )
    assert(err == ExcubiaError::GateAlreadySet.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: FreeForAllExcubiaMsg::Check { passerby: passerby },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: FreeForAllExcubiaMsg::HasPassed { passerby: passerby },
        )
    assert(!has_passed)

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: FreeForAllExcubiaMsg::Pass { passerby: passerby },
        )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::FreeForAllPass { target: excubia, passerby: passerby },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: FreeForAllExcubiaMsg::HasPassed { passerby: passerby },
        )
    assert(has_passed)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::FreeForAllPass { target: excubia, passerby: passerby },
        )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test]
fn test_erc721_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2010)
    let nft = evm.create2<MockERC721>(value: 0, args: (), salt: 2011)
    let excubia = evm.create2<ERC721Excubia>(value: 0, args: (nft,), salt: 2012)
    let passerby = Address { inner: 0x2001 }
    let other = Address { inner: 0x2002 }

    evm.call(
        addr: nft,
        gas: 100000,
        value: 0,
        message: MockERC721Msg::Mint { token_id: 0, owner: passerby },
    )
    evm.call(
        addr: nft,
        gas: 100000,
        value: 0,
        message: MockERC721Msg::Mint { token_id: 1, owner: other },
    )

    let trait_value: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ERC721ExcubiaMsg::Trait {},
        )
    assert(trait_value == EXCUBIA_TRAIT_ERC721)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::ERC721SetGate { target: excubia, gate: caller },
        )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ERC721ExcubiaMsg::SetGate { gate: Address::zero() },
        )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ERC721ExcubiaMsg::SetGate { gate: caller },
        )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ERC721ExcubiaMsg::Check { passerby: passerby, token_id: 1 },
        )
    assert(err == ExcubiaError::UnexpectedTokenOwner.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ERC721ExcubiaMsg::Check { passerby: passerby, token_id: 0 },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ERC721ExcubiaMsg::HasPassedTokenId { token_id: 0 },
        )
    assert(!has_passed)

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ERC721ExcubiaMsg::Pass { passerby: passerby, token_id: 0 },
        )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::ERC721Pass {
                target: excubia,
                passerby: passerby,
                token_id: 1,
            },
        )
    assert(err == ExcubiaError::UnexpectedTokenOwner.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::ERC721Pass {
                target: excubia,
                passerby: passerby,
                token_id: 0,
            },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ERC721ExcubiaMsg::HasPassedTokenId { token_id: 0 },
        )
    assert(has_passed)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::ERC721Pass {
                target: excubia,
                passerby: passerby,
                token_id: 0,
            },
        )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

