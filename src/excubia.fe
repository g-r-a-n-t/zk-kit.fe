const EXCUBIA_HAT_LIMIT: usize = 4
const GITCOIN_SCORE_FACTOR: u256 = 100
const EAS_SCHEMA_ID: u256 = 0xfdcfdad2dbe7489e0ce56b260348b7f14e8365a8a325aef9834818c00d46b31b

enum ExcubiaError {
    None,
    OwnerOnly,
    ZeroAddress,
    GateOnly,
    GateAlreadySet,
    AlreadyPassed,
    UnexpectedTokenOwner,
    InsufficientScore,
    NotWearingCriterionHat,
    NotCriterionHat,
    UnexpectedSchema,
    UnexpectedAttester,
    UnexpectedRecipient,
    RevokedAttestation,
    InvalidGroup,
    InvalidProof,
    UnexpectedScope,
    InvalidEventId,
    InvalidSigners,
    InvalidWatermark,
}

impl ExcubiaError {
    pub fn is_none(self) -> bool {
        match self {
            ExcubiaError::None => true,
            _ => false,
        }
    }
    pub fn code(self) -> u256 {
        match self {
            ExcubiaError::None => 0,
            ExcubiaError::OwnerOnly => 1,
            ExcubiaError::ZeroAddress => 2,
            ExcubiaError::GateOnly => 3,
            ExcubiaError::GateAlreadySet => 4,
            ExcubiaError::AlreadyPassed => 5,
            ExcubiaError::UnexpectedTokenOwner => 6,
            ExcubiaError::InsufficientScore => 7,
            ExcubiaError::NotWearingCriterionHat => 8,
            ExcubiaError::NotCriterionHat => 9,
            ExcubiaError::UnexpectedSchema => 10,
            ExcubiaError::UnexpectedAttester => 11,
            ExcubiaError::UnexpectedRecipient => 12,
            ExcubiaError::RevokedAttestation => 13,
            ExcubiaError::InvalidGroup => 14,
            ExcubiaError::InvalidProof => 15,
            ExcubiaError::UnexpectedScope => 16,
            ExcubiaError::InvalidEventId => 17,
            ExcubiaError::InvalidSigners => 18,
            ExcubiaError::InvalidWatermark => 19,
        }
    }
}

#[event]
struct GateSetEvent {
    #[indexed]
    gate: Address,
}

#[event]
struct GatePassedEvent {
    #[indexed]
    passerby: Address,
    #[indexed]
    gate: Address,
}

fn excubia_set_gate_err(
    owner: Address,
    gate: Address,
    caller: Address,
    new_gate: Address,
) -> ExcubiaError {
    if caller != owner {
        return ExcubiaError::OwnerOnly
    }
    if new_gate == Address::zero() {
        return ExcubiaError::ZeroAddress
    }
    if gate != Address::zero() {
        return ExcubiaError::GateAlreadySet
    }
    ExcubiaError::None
}

fn excubia_gate_only_err(gate: Address, caller: Address) -> ExcubiaError {
    if caller != gate {
        return ExcubiaError::GateOnly
    }
    ExcubiaError::None
}

fn excubia_pass_common_err(gate: Address, caller: Address, already_passed: bool) -> ExcubiaError {
    let err = excubia_gate_only_err(gate, caller)
    if !err.is_none() {
        return err
    }
    if already_passed {
        return ExcubiaError::AlreadyPassed
    }
    ExcubiaError::None
}

fn excubia_unexpected_owner_err(owner_inner: u256, passerby: Address) -> ExcubiaError {
    if owner_inner != passerby.inner {
        return ExcubiaError::UnexpectedTokenOwner
    }
    ExcubiaError::None
}

fn excubia_insufficient_score_err(score: u256, threshold_score: u256) -> ExcubiaError {
    if (score / GITCOIN_SCORE_FACTOR) < threshold_score {
        return ExcubiaError::InsufficientScore
    }
    ExcubiaError::None
}

fn excubia_hat_membership_err(is_criterion_hat: bool, is_wearer: bool) -> ExcubiaError {
    if !is_criterion_hat {
        return ExcubiaError::NotCriterionHat
    }
    if !is_wearer {
        return ExcubiaError::NotWearingCriterionHat
    }
    ExcubiaError::None
}

fn emit_gate_set(gate: Address) uses (log: mut Log) {
    log.emit(GateSetEvent { gate })
}

fn emit_gate_passed(passerby: Address, gate: Address) uses (log: mut Log) {
    log.emit(GatePassedEvent { passerby, gate })
}

fn eas_attestation_err(
    eas: Address,
    attestation_id: u256,
    schema: u256,
    attester: Address,
    passerby: Address,
) -> ExcubiaError
uses (call: mut Call)
{
    let actual_schema: u256 = call
        .call(
            addr: eas,
            gas: 100000,
            value: 0,
            message: MockEASMsg::GetSchema { uid: attestation_id },
        )

    let actual_attester: u256 = call
        .call(
            addr: eas,
            gas: 100000,
            value: 0,
            message: MockEASMsg::GetAttester { uid: attestation_id },
        )

    let actual_recipient: u256 = call
        .call(
            addr: eas,
            gas: 100000,
            value: 0,
            message: MockEASMsg::GetRecipient { uid: attestation_id },
        )

    let revocation_time: u256 = call
        .call(
            addr: eas,
            gas: 100000,
            value: 0,
            message: MockEASMsg::GetRevocationTime { uid: attestation_id },
        )
    eas_attestation_fields_err(
        actual_schema: actual_schema,
        expected_schema: schema,
        actual_attester: actual_attester,
        expected_attester: attester,
        actual_recipient: actual_recipient,
        expected_recipient: passerby,
        revocation_time: revocation_time,
    )
}

fn eas_attestation_fields_err(
    actual_schema: u256,
    expected_schema: u256,
    actual_attester: u256,
    expected_attester: Address,
    actual_recipient: u256,
    expected_recipient: Address,
    revocation_time: u256,
) -> ExcubiaError {
    if actual_schema != expected_schema {
        return ExcubiaError::UnexpectedSchema
    }
    if actual_attester != expected_attester.inner {
        return ExcubiaError::UnexpectedAttester
    }
    if actual_recipient != expected_recipient.inner {
        return ExcubiaError::UnexpectedRecipient
    }
    if revocation_time != 0 {
        return ExcubiaError::RevokedAttestation
    }
    ExcubiaError::None
}

fn semaphore_proof_err(
    semaphore: Address,
    group_id: u256,
    scope: u256,
    nullifier: u256,
) -> ExcubiaError
uses (call: mut Call)
{
    let is_valid: bool = call
        .call(
            addr: semaphore,
            gas: 100000,
            value: 0,
            message: MockSemaphoreMsg::VerifyProof { group_id: group_id, nullifier: nullifier },
        )
    semaphore_proof_validity_err(group_id: group_id, scope: scope, is_valid: is_valid)
}

fn semaphore_proof_validity_err(group_id: u256, scope: u256, is_valid: bool) -> ExcubiaError {
    if scope != group_id {
        return ExcubiaError::UnexpectedScope
    }
    if !is_valid {
        return ExcubiaError::InvalidProof
    }

    ExcubiaError::None
}

fn zkeddsa_ecmul(x: u256, y: u256, scalar: u256) -> (bool, u256, u256) {
    let (out_x, out_y) = ec_mul(px: x, py: y, s: scalar)
    (true, out_x, out_y)
}

fn zkeddsa_ecadd(x0: u256, y0: u256, x1: u256, y1: u256) -> (bool, u256, u256) {
    let (out_x, out_y) = ec_add(ax: x0, ay: y0, bx: x1, by: y1)
    (true, out_x, out_y)
}

fn zkeddsa_g1_mul_acc(acc_x: u256, acc_y: u256, point: [u256; 2], scalar: u256) -> (
    bool,
    u256,
    u256,
) {
    let (mul_ok, mul_x, mul_y) = zkeddsa_ecmul(x: point[0], y: point[1], scalar: scalar)
    if !mul_ok {
        return (false, 0, 0)
    }

    let (add_ok, add_x, add_y) = zkeddsa_ecadd(x0: acc_x, y0: acc_y, x1: mul_x, y1: mul_y)
    if !add_ok {
        return (false, 0, 0)
    }

    (true, add_x, add_y)
}

fn zkeddsa_verify_pairing(
    p_a: [u256; 2],
    p_b: [[u256; 2]; 2],
    p_c: [u256; 2],
    vk_x: [u256; 2],
) -> bool
uses (mem: mut RawMem, call: mut Call)
{
    let pairing_input: [u256; 24] = [
        p_a[0],
        mulmod(a: p_a[1], b: ZKEDDSA_Q - 1, m: ZKEDDSA_Q),
        p_b[0][0],
        p_b[0][1],
        p_b[1][0],
        p_b[1][1],
        ZKEDDSA_ALPHAX,
        ZKEDDSA_ALPHAY,
        ZKEDDSA_BETAX1,
        ZKEDDSA_BETAX2,
        ZKEDDSA_BETAY1,
        ZKEDDSA_BETAY2,
        vk_x[0],
        vk_x[1],
        ZKEDDSA_GAMMAX1,
        ZKEDDSA_GAMMAX2,
        ZKEDDSA_GAMMAY1,
        ZKEDDSA_GAMMAY2,
        p_c[0],
        p_c[1],
        ZKEDDSA_DELTAX1,
        ZKEDDSA_DELTAX2,
        ZKEDDSA_DELTAY1,
        ZKEDDSA_DELTAY2,
    ]
    let pairing_len = 24 * 32
    let pairing_ptr = mem::alloc(pairing_len)
    let mut i: usize = 0
    let mut offset: u256 = 0
    while i < 24 {
        mem.mstore(addr: pairing_ptr + offset, value: pairing_input[i])
        i += 1
        offset += 32
    }

    // The pairing precompile can fail for invalid proof input. Generated
    // Solidity verifiers treat that as `false`, not as a bubbled revert, so
    // this verifier must preserve that behavior for invalid-proof checks.
    let ok = call
        .raw_call(
            addr: Address { inner: 8 },
            gas: 1000000,
            value: 0,
            args_offset: pairing_ptr,
            args_len: pairing_len,
        )
    if !ok { return false }

    let output = last_returndata()
    output.len >= 32 && mem.mload(output.base) != 0
}

fn zkeddsa_verify_proof(
    p_a: [u256; 2],
    p_b: [[u256; 2]; 2],
    p_c: [u256; 2],
    pub_signals: [u256; 38],
) -> bool
uses (mem: mut RawMem, call: mut Call)
{
    let mut i: usize = 0
    while i < 38 {
        if pub_signals[i] >= ZKEDDSA_R {
            return false
        }
        i += 1
    }

    let mut vk_x0 = ZKEDDSA_IC[0][0]
    let mut vk_x1 = ZKEDDSA_IC[0][1]
    i = 0
    while i < 38 {
        let (ok, next_x0, next_x1) = zkeddsa_g1_mul_acc(
            acc_x: vk_x0,
            acc_y: vk_x1,
            point: ZKEDDSA_IC[i + 1],
            scalar: pub_signals[i],
        )
        if !ok { return false }
        vk_x0 = next_x0
        vk_x1 = next_x1
        i += 1
    }

    zkeddsa_verify_pairing(p_a: p_a, p_b: p_b, p_c: p_c, vk_x: [vk_x0, vk_x1])
}

pub msg FreeForAllExcubiaMsg {
    #[selector = 0x51000001]
    SetGate { gate: Address } -> u256,
    #[selector = 0x51000002]
    Check { passerby: Address } -> u256,
    #[selector = 0x51000003]
    Pass { passerby: Address } -> u256,
    #[selector = 0x51000004]
    Gate -> u256,
    #[selector = 0x51000005]
    Trait -> u256,
    #[selector = 0x51000006]
    HasPassed { passerby: Address } -> bool,
}

struct FreeForAllExcubiaStore {
    owner: Address,
    gate: Address,
    passed_passersby: StorageMap<Address, bool>,
}

pub contract FreeForAllExcubia uses (ctx: Ctx, log: mut Log) {
    mut store: FreeForAllExcubiaStore,

    init()
    uses (mut store, ctx)
    {
        store.owner = ctx.caller()
        store.gate = Address::zero()
    }

    recv FreeForAllExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(
                owner: store.owner,
                gate: store.gate,
                caller: ctx.caller(),
                new_gate: gate,
            )
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check { passerby } -> u256 {
            let _ = passerby
            ExcubiaError::None.code()
        }

        Pass { passerby } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_pass_common_err(
                gate: store.gate,
                caller: ctx.caller(),
                already_passed: store.passed_passersby.get(key: passerby),
            )
            if !err.is_none() {
                return err.code()
            }

            store.passed_passersby.set(key: passerby, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_FREE_FOR_ALL
        }

        HasPassed { passerby } -> bool uses (store) {
            store.passed_passersby.get(key: passerby)
        }
    }
}

pub msg ERC721ExcubiaMsg {
    #[selector = 0x53000001]
    SetGate { gate: Address } -> u256,
    #[selector = 0x53000002]
    Check { passerby: Address, token_id: u256 } -> u256,
    #[selector = 0x53000003]
    Pass { passerby: Address, token_id: u256 } -> u256,
    #[selector = 0x53000004]
    Gate -> u256,
    #[selector = 0x53000005]
    Trait -> u256,
    #[selector = 0x53000006]
    HasPassedTokenId { token_id: u256 } -> bool,
}

struct ERC721ExcubiaStore {
    owner: Address,
    gate: Address,
    nft: Address,
    passed_token_ids: StorageMap<u256, bool>,
}

pub contract ERC721Excubia uses (ctx: Ctx, call: mut Call, log: mut Log) {
    mut store: ERC721ExcubiaStore,

    init(nft: Address)
    uses (mut store, ctx)
    {
        assert(nft != Address::zero())
        store.owner = ctx.caller()
        store.gate = Address::zero()
        store.nft = nft
    }

    recv ERC721ExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(
                owner: store.owner,
                gate: store.gate,
                caller: ctx.caller(),
                new_gate: gate,
            )
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check { passerby, token_id } -> u256 uses (store, mut call) {
            let owner_inner: u256 = call
                .call(
                    addr: store.nft,
                    gas: 100000,
                    value: 0,
                    message: MockERC721Msg::OwnerOf { token_id: token_id },
                )
            excubia_unexpected_owner_err(owner_inner: owner_inner, passerby: passerby).code()
        }

        Pass { passerby, token_id } -> u256 uses (mut store, ctx, mut call, mut log) {
            let err = excubia_pass_common_err(
                gate: store.gate,
                caller: ctx.caller(),
                already_passed: store.passed_token_ids.get(key: token_id),
            )
            if !err.is_none() {
                return err.code()
            }

            let owner_inner: u256 = call
                .call(
                    addr: store.nft,
                    gas: 100000,
                    value: 0,
                    message: MockERC721Msg::OwnerOf { token_id: token_id },
                )
            let err = excubia_unexpected_owner_err(owner_inner: owner_inner, passerby: passerby)
            if !err.is_none() {
                return err.code()
            }

            store.passed_token_ids.set(key: token_id, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_ERC721
        }

        HasPassedTokenId { token_id } -> bool uses (store) {
            store.passed_token_ids.get(key: token_id)
        }
    }
}

pub msg GitcoinPassportExcubiaMsg {
    #[selector = 0x55000001]
    SetGate { gate: Address } -> u256,
    #[selector = 0x55000002]
    Check { passerby: Address } -> u256,
    #[selector = 0x55000003]
    Pass { passerby: Address } -> u256,
    #[selector = 0x55000004]
    Gate -> u256,
    #[selector = 0x55000005]
    Trait -> u256,
    #[selector = 0x55000006]
    HasPassed { passerby: Address } -> bool,
}

struct GitcoinPassportExcubiaStore {
    owner: Address,
    gate: Address,
    decoder: Address,
    threshold_score: u256,
    passed_users: StorageMap<Address, bool>,
}

pub contract GitcoinPassportExcubia uses (ctx: Ctx, call: mut Call, log: mut Log) {
    mut store: GitcoinPassportExcubiaStore,

    init(decoder: Address, threshold_score: u256)
    uses (mut store, ctx)
    {
        assert(decoder != Address::zero())
        assert(threshold_score > 0)
        store.owner = ctx.caller()
        store.gate = Address::zero()
        store.decoder = decoder
        store.threshold_score = threshold_score
    }

    recv GitcoinPassportExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(
                owner: store.owner,
                gate: store.gate,
                caller: ctx.caller(),
                new_gate: gate,
            )
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check { passerby } -> u256 uses (store, mut call) {
            let score: u256 = call
                .call(
                    addr: store.decoder,
                    gas: 100000,
                    value: 0,
                    message: MockGitcoinPassportDecoderMsg::GetScore { user: passerby },
                )
            excubia_insufficient_score_err(score: score, threshold_score: store.threshold_score)
                .code()
        }

        Pass { passerby } -> u256 uses (mut store, ctx, mut call, mut log) {
            let err = excubia_pass_common_err(
                gate: store.gate,
                caller: ctx.caller(),
                already_passed: store.passed_users.get(key: passerby),
            )
            if !err.is_none() {
                return err.code()
            }

            let score: u256 = call
                .call(
                    addr: store.decoder,
                    gas: 100000,
                    value: 0,
                    message: MockGitcoinPassportDecoderMsg::GetScore { user: passerby },
                )
            let err = excubia_insufficient_score_err(
                score: score,
                threshold_score: store.threshold_score,
            )
            if !err.is_none() {
                return err.code()
            }

            store.passed_users.set(key: passerby, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_GITCOIN_PASSPORT
        }

        HasPassed { passerby } -> bool uses (store) {
            store.passed_users.get(key: passerby)
        }
    }
}

pub msg HatsExcubiaMsg {
    #[selector = 0x57000001]
    SetGate { gate: Address } -> u256,
    #[selector = 0x57000002]
    Check { passerby: Address, hat: u256 } -> u256,
    #[selector = 0x57000003]
    Pass { passerby: Address, hat: u256 } -> u256,
    #[selector = 0x57000004]
    Gate -> u256,
    #[selector = 0x57000005]
    Trait -> u256,
    #[selector = 0x57000006]
    HasPassed { passerby: Address } -> bool,
    #[selector = 0x57000007]
    IsCriterionHat { hat: u256 } -> bool,
}

struct HatsExcubiaStore {
    owner: Address,
    gate: Address,
    hats: Address,
    criterion_hats: StorageMap<u256, bool>,
    passed_users: StorageMap<Address, bool>,
}

pub contract HatsExcubia uses (ctx: Ctx, call: mut Call, log: mut Log) {
    mut store: HatsExcubiaStore,

    init(hats: Address, criterion_hats: [u256; EXCUBIA_HAT_LIMIT], count: usize)
    uses (mut store, ctx)
    {
        assert(hats != Address::zero())
        assert(count > 0)
        assert(count <= EXCUBIA_HAT_LIMIT)

        store.owner = ctx.caller()
        store.gate = Address::zero()
        store.hats = hats

        let mut i: usize = 0
        while i < count {
            store.criterion_hats.set(key: criterion_hats[i], value: true)
            i += 1
        }
    }

    recv HatsExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(
                owner: store.owner,
                gate: store.gate,
                caller: ctx.caller(),
                new_gate: gate,
            )
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check { passerby, hat } -> u256 uses (store, mut call) {
            let is_criterion_hat = store.criterion_hats.get(key: hat)
            let is_wearer: bool = call
                .call(
                    addr: store.hats,
                    gas: 100000,
                    value: 0,
                    message: MockHatsMsg::IsWearerOfHat { user: passerby, hat: hat },
                )
            excubia_hat_membership_err(is_criterion_hat: is_criterion_hat, is_wearer: is_wearer)
                .code()
        }

        Pass { passerby, hat } -> u256 uses (mut store, ctx, mut call, mut log) {
            let err = excubia_pass_common_err(
                gate: store.gate,
                caller: ctx.caller(),
                already_passed: store.passed_users.get(key: passerby),
            )
            if !err.is_none() {
                return err.code()
            }

            let is_criterion_hat = store.criterion_hats.get(key: hat)
            let is_wearer: bool = call
                .call(
                    addr: store.hats,
                    gas: 100000,
                    value: 0,
                    message: MockHatsMsg::IsWearerOfHat { user: passerby, hat: hat },
                )
            let err = excubia_hat_membership_err(
                is_criterion_hat: is_criterion_hat,
                is_wearer: is_wearer,
            )
            if !err.is_none() {
                return err.code()
            }

            store.passed_users.set(key: passerby, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_HATS
        }

        HasPassed { passerby } -> bool uses (store) {
            store.passed_users.get(key: passerby)
        }

        IsCriterionHat { hat } -> bool uses (store) {
            store.criterion_hats.get(key: hat)
        }
    }
}

