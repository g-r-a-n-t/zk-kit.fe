const EXCUBIA_HAT_LIMIT: usize = 4
const GITCOIN_SCORE_FACTOR: u256 = 100
const EAS_SCHEMA_ID: u256 = 0xfdcfdad2dbe7489e0ce56b260348b7f14e8365a8a325aef9834818c00d46b31b

enum ExcubiaError {
    None,
    OwnerOnly,
    ZeroAddress,
    GateOnly,
    GateAlreadySet,
    AlreadyPassed,
    UnexpectedTokenOwner,
    InsufficientScore,
    NotWearingCriterionHat,
    NotCriterionHat,
    UnexpectedSchema,
    UnexpectedAttester,
    UnexpectedRecipient,
    RevokedAttestation,
    InvalidGroup,
    InvalidProof,
    UnexpectedScope,
    InvalidEventId,
    InvalidSigners,
    InvalidWatermark,
}

impl ExcubiaError {
    pub fn is_none(self) -> bool {
        match self {
            ExcubiaError::None => true,
            _ => false,
        }
    }
    pub fn code(self) -> u256 {
        match self {
            ExcubiaError::None => 0,
            ExcubiaError::OwnerOnly => 1,
            ExcubiaError::ZeroAddress => 2,
            ExcubiaError::GateOnly => 3,
            ExcubiaError::GateAlreadySet => 4,
            ExcubiaError::AlreadyPassed => 5,
            ExcubiaError::UnexpectedTokenOwner => 6,
            ExcubiaError::InsufficientScore => 7,
            ExcubiaError::NotWearingCriterionHat => 8,
            ExcubiaError::NotCriterionHat => 9,
            ExcubiaError::UnexpectedSchema => 10,
            ExcubiaError::UnexpectedAttester => 11,
            ExcubiaError::UnexpectedRecipient => 12,
            ExcubiaError::RevokedAttestation => 13,
            ExcubiaError::InvalidGroup => 14,
            ExcubiaError::InvalidProof => 15,
            ExcubiaError::UnexpectedScope => 16,
            ExcubiaError::InvalidEventId => 17,
            ExcubiaError::InvalidSigners => 18,
            ExcubiaError::InvalidWatermark => 19,
        }
    }
}

#[event]
struct GateSetEvent {
    #[indexed]
    gate: Address,
}

#[event]
struct GatePassedEvent {
    #[indexed]
    passerby: Address,
    #[indexed]
    gate: Address,
}

fn excubia_set_gate_err(
    owner: Address,
    gate: Address,
    caller: Address,
    new_gate: Address,
) -> ExcubiaError {
    if caller != owner {
        return ExcubiaError::OwnerOnly
    }
    if new_gate == Address::zero() {
        return ExcubiaError::ZeroAddress
    }
    if gate != Address::zero() {
        return ExcubiaError::GateAlreadySet
    }
    ExcubiaError::None
}

fn excubia_gate_only_err(gate: Address, caller: Address) -> ExcubiaError {
    if caller != gate {
        return ExcubiaError::GateOnly
    }
    ExcubiaError::None
}

fn excubia_pass_common_err(gate: Address, caller: Address, already_passed: bool) -> ExcubiaError {
    let err = excubia_gate_only_err(gate, caller)
    if !err.is_none() {
        return err
    }
    if already_passed {
        return ExcubiaError::AlreadyPassed
    }
    ExcubiaError::None
}

fn excubia_unexpected_owner_err(owner_inner: u256, passerby: Address) -> ExcubiaError {
    if owner_inner != passerby.inner {
        return ExcubiaError::UnexpectedTokenOwner
    }
    ExcubiaError::None
}

fn excubia_insufficient_score_err(score: u256, threshold_score: u256) -> ExcubiaError {
    if (score / GITCOIN_SCORE_FACTOR) < threshold_score {
        return ExcubiaError::InsufficientScore
    }
    ExcubiaError::None
}

fn excubia_hat_membership_err(is_criterion_hat: bool, is_wearer: bool) -> ExcubiaError {
    if !is_criterion_hat {
        return ExcubiaError::NotCriterionHat
    }
    if !is_wearer {
        return ExcubiaError::NotWearingCriterionHat
    }
    ExcubiaError::None
}

fn emit_gate_set(gate: Address) uses (log: mut Log) {
    log.emit(GateSetEvent { gate })
}

fn emit_gate_passed(passerby: Address, gate: Address) uses (log: mut Log) {
    log.emit(GatePassedEvent { passerby, gate })
}

fn eas_attestation_err(
    eas: Address,
    attestation_id: u256,
    schema: u256,
    attester: Address,
    passerby: Address,
) -> ExcubiaError
uses (call: mut Call)
{
    let actual_schema: u256 = call
        .call(
            addr: eas,
            gas: 100000,
            value: 0,
            message: MockEASMsg::GetSchema { uid: attestation_id },
        )

    let actual_attester: u256 = call
        .call(
            addr: eas,
            gas: 100000,
            value: 0,
            message: MockEASMsg::GetAttester { uid: attestation_id },
        )

    let actual_recipient: u256 = call
        .call(
            addr: eas,
            gas: 100000,
            value: 0,
            message: MockEASMsg::GetRecipient { uid: attestation_id },
        )

    let revocation_time: u256 = call
        .call(
            addr: eas,
            gas: 100000,
            value: 0,
            message: MockEASMsg::GetRevocationTime { uid: attestation_id },
        )
    eas_attestation_fields_err(
        actual_schema: actual_schema,
        expected_schema: schema,
        actual_attester: actual_attester,
        expected_attester: attester,
        actual_recipient: actual_recipient,
        expected_recipient: passerby,
        revocation_time: revocation_time,
    )
}

fn eas_attestation_fields_err(
    actual_schema: u256,
    expected_schema: u256,
    actual_attester: u256,
    expected_attester: Address,
    actual_recipient: u256,
    expected_recipient: Address,
    revocation_time: u256,
) -> ExcubiaError {
    if actual_schema != expected_schema {
        return ExcubiaError::UnexpectedSchema
    }
    if actual_attester != expected_attester.inner {
        return ExcubiaError::UnexpectedAttester
    }
    if actual_recipient != expected_recipient.inner {
        return ExcubiaError::UnexpectedRecipient
    }
    if revocation_time != 0 {
        return ExcubiaError::RevokedAttestation
    }
    ExcubiaError::None
}

fn semaphore_proof_err(
    semaphore: Address,
    group_id: u256,
    scope: u256,
    nullifier: u256,
) -> ExcubiaError
uses (call: mut Call)
{
    let is_valid: bool = call
        .call(
            addr: semaphore,
            gas: 100000,
            value: 0,
            message: MockSemaphoreMsg::VerifyProof { group_id: group_id, nullifier: nullifier },
        )
    semaphore_proof_validity_err(group_id: group_id, scope: scope, is_valid: is_valid)
}

fn semaphore_proof_validity_err(group_id: u256, scope: u256, is_valid: bool) -> ExcubiaError {
    if scope != group_id {
        return ExcubiaError::UnexpectedScope
    }
    if !is_valid {
        return ExcubiaError::InvalidProof
    }

    ExcubiaError::None
}

fn encode_sol_to_ptr<T>(_ value: own T, _ ptr: u256) where T: Encode<Sol> {
    value.encode_to_ptr(ptr)
}

fn zkeddsa_ecmul(x: u256, y: u256, scalar: u256) -> (bool, u256, u256) {
    let (out_x, out_y) = ec_mul(px: x, py: y, s: scalar)
    (true, out_x, out_y)
}

fn zkeddsa_ecadd(x0: u256, y0: u256, x1: u256, y1: u256) -> (bool, u256, u256) {
    let (out_x, out_y) = ec_add(ax: x0, ay: y0, bx: x1, by: y1)
    (true, out_x, out_y)
}

fn zkeddsa_g1_mul_acc(acc_x: u256, acc_y: u256, point: [u256; 2], scalar: u256) -> (
    bool,
    u256,
    u256,
) {
    let (mul_ok, mul_x, mul_y) = zkeddsa_ecmul(x: point[0], y: point[1], scalar: scalar)
    if !mul_ok {
        return (false, 0, 0)
    }

    let (add_ok, add_x, add_y) = zkeddsa_ecadd(x0: acc_x, y0: acc_y, x1: mul_x, y1: mul_y)
    if !add_ok {
        return (false, 0, 0)
    }

    (true, add_x, add_y)
}

fn zkeddsa_verify_pairing(
    p_a: [u256; 2],
    p_b: [[u256; 2]; 2],
    p_c: [u256; 2],
    vk_x: [u256; 2],
) -> bool {
    let pairing_input: [u256; 24] = [
        p_a[0],
        mulmod(a: p_a[1], b: ZKEDDSA_Q - 1, m: ZKEDDSA_Q),
        p_b[0][0],
        p_b[0][1],
        p_b[1][0],
        p_b[1][1],
        ZKEDDSA_ALPHAX,
        ZKEDDSA_ALPHAY,
        ZKEDDSA_BETAX1,
        ZKEDDSA_BETAX2,
        ZKEDDSA_BETAY1,
        ZKEDDSA_BETAY2,
        vk_x[0],
        vk_x[1],
        ZKEDDSA_GAMMAX1,
        ZKEDDSA_GAMMAX2,
        ZKEDDSA_GAMMAY1,
        ZKEDDSA_GAMMAY2,
        p_c[0],
        p_c[1],
        ZKEDDSA_DELTAX1,
        ZKEDDSA_DELTAX2,
        ZKEDDSA_DELTAY1,
        ZKEDDSA_DELTAY2,
    ]
    let pairing_len = encoded_size<[u256; 24]>()
    let pairing_ptr = mem::alloc(pairing_len)
    encode_sol_to_ptr(pairing_input, pairing_ptr)
    ec_pairing(offset: pairing_ptr, len: pairing_len)
}

fn zkeddsa_verify_proof(
    p_a: [u256; 2],
    p_b: [[u256; 2]; 2],
    p_c: [u256; 2],
    pub_signals: [u256; 38],
) -> bool {
    let mut i: usize = 0
    while i < 38 {
        if pub_signals[i] >= ZKEDDSA_R {
            return false
        }
        i += 1
    }

    let mut vk_x0 = ZKEDDSA_IC[0][0]
    let mut vk_x1 = ZKEDDSA_IC[0][1]
    i = 0
    while i < 38 {
        let (ok, next_x0, next_x1) = zkeddsa_g1_mul_acc(
            acc_x: vk_x0,
            acc_y: vk_x1,
            point: ZKEDDSA_IC[i + 1],
            scalar: pub_signals[i],
        )
        if !ok { return false }
        vk_x0 = next_x0
        vk_x1 = next_x1
        i += 1
    }

    zkeddsa_verify_pairing(p_a: p_a, p_b: p_b, p_c: p_c, vk_x: [vk_x0, vk_x1])
}

fn zkeddsa_proof_err(
    valid_event_id: u256,
    valid_signer_0: u256,
    valid_signer_1: u256,
    passerby: Address,
    p_a: [u256; 2],
    p_b: [[u256; 2]; 2],
    p_c: [u256; 2],
    pub_signals: [u256; 38],
) -> ExcubiaError {
    let is_valid = zkeddsa_verify_proof(p_a: p_a, p_b: p_b, p_c: p_c, pub_signals: pub_signals)
    zkeddsa_proof_validity_err(
        valid_event_id: valid_event_id,
        valid_signer_0: valid_signer_0,
        valid_signer_1: valid_signer_1,
        passerby: passerby,
        is_valid: is_valid,
        pub_signals: pub_signals,
    )
}

fn zkeddsa_proof_validity_err(
    valid_event_id: u256,
    valid_signer_0: u256,
    valid_signer_1: u256,
    passerby: Address,
    is_valid: bool,
    pub_signals: [u256; 38],
) -> ExcubiaError {
    if pub_signals[13] != valid_signer_0 || pub_signals[14] != valid_signer_1 {
        return ExcubiaError::InvalidSigners
    }
    if pub_signals[15] != valid_event_id {
        return ExcubiaError::InvalidEventId
    }
    if pub_signals[37] != passerby.inner {
        return ExcubiaError::InvalidWatermark
    }
    if !is_valid {
        return ExcubiaError::InvalidProof
    }
    ExcubiaError::None
}

// TODO: Re-enable the Excubia contract wrappers once the library-first refactor is settled and
// the Fe message ABI is stable enough for the full wrapper and parity-test surface again.
// The real gatekeeping logic lives in the helper functions above; these wrappers are
// intentionally disabled for now while zk-kit-fe stays library-first.
