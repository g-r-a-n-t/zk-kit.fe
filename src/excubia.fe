                value: 0,
                message: HatsExcubiaMsg::SetGate { gate: gate },
            )
        }

        HatsPass { target, passerby, hat } -> u256
        uses (mut call)
        {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: HatsExcubiaMsg::Pass { passerby: passerby, hat: hat },
            )
