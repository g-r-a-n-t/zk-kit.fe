    } -> u256,
    #[selector = 0x5c000003]
    Pass {
        passerby: Address,
        merkle_tree_depth: u256,
        merkle_tree_root: u256,
        nullifier: u256,
        message_value: u256,
        scope: u256,
        points: [u256; 8],
    } -> u256,
    #[selector = 0x5c000004]
