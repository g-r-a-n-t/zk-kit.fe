#[test]
fn test_hats_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2030)
    let hats = evm.create2<MockHats>(value: 0, args: (), salt: 2031)
    let excubia = evm.create2<HatsExcubia>(value: 0, args: (hats, [1, 0, 0, 0], 1), salt: 2032)
    let passerby = Address { inner: 0x4001 }
    let not_wearer = Address { inner: 0x4002 }

    evm.call(
        addr: hats,
        gas: 100000,
        value: 0,
        message: MockHatsMsg::SetWearer { user: passerby, hat: 1, is_wearer: true },
    )

    let trait_value: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: HatsExcubiaMsg::Trait {},
        )
    assert(trait_value == EXCUBIA_TRAIT_HATS)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::HatsSetGate { target: excubia, gate: caller },
        )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: HatsExcubiaMsg::SetGate { gate: Address::zero() },
        )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: HatsExcubiaMsg::SetGate { gate: caller },
        )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: HatsExcubiaMsg::Check { passerby: passerby, hat: 2 },
        )
    assert(err == ExcubiaError::NotCriterionHat.code())

    let is_criterion: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: HatsExcubiaMsg::IsCriterionHat { hat: 2 },
        )
    assert(!is_criterion)

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: HatsExcubiaMsg::Check { passerby: not_wearer, hat: 1 },
        )
    assert(err == ExcubiaError::NotWearingCriterionHat.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: HatsExcubiaMsg::Check { passerby: passerby, hat: 1 },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: HatsExcubiaMsg::HasPassed { passerby: passerby },
        )
    assert(!has_passed)

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: HatsExcubiaMsg::Pass { passerby: passerby, hat: 1 },
        )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::HatsPass { target: excubia, passerby: passerby, hat: 2 },
        )
    assert(err == ExcubiaError::NotCriterionHat.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::HatsPass { target: excubia, passerby: not_wearer, hat: 1 },
        )
    assert(err == ExcubiaError::NotWearingCriterionHat.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::HatsPass { target: excubia, passerby: passerby, hat: 1 },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: HatsExcubiaMsg::HasPassed { passerby: passerby },
        )
    assert(has_passed)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::HatsPass { target: excubia, passerby: passerby, hat: 1 },
        )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test]
fn test_eas_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2050)
    let passerby = Address { inner: 0x5001 }
    let attester = Address { inner: 0x5002 }
    let eas = evm.create2<MockEAS>(
            value: 0,
            args: (passerby, attester, EAS_SCHEMA_ID),
            salt: 2051,
        )
    let excubia = evm
        .create2<EASExcubia>(value: 0, args: (eas, attester, EAS_SCHEMA_ID), salt: 2052)

    let trait_value: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::Trait {},
        )
    assert(trait_value == EXCUBIA_TRAIT_EAS)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::EASSetGate { target: excubia, gate: caller },
        )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::SetGate { gate: Address::zero() },
        )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::SetGate { gate: caller },
        )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::Check { passerby: passerby, attestation_id: 4 },
        )
    assert(err == ExcubiaError::UnexpectedRecipient.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::Check { passerby: passerby, attestation_id: 2 },
        )
    assert(err == ExcubiaError::RevokedAttestation.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::Check { passerby: passerby, attestation_id: 3 },
        )
    assert(err == ExcubiaError::UnexpectedSchema.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::Check { passerby: passerby, attestation_id: 5 },
        )
    assert(err == ExcubiaError::UnexpectedAttester.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::Check { passerby: passerby, attestation_id: 1 },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::HasPassedAttestation { attestation_id: 1 },
        )
    assert(!has_passed)

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::Pass { passerby: passerby, attestation_id: 1 },
        )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::EASPass {
                target: excubia,
                passerby: passerby,
                attestation_id: 4,
            },
        )
    assert(err == ExcubiaError::UnexpectedRecipient.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::EASPass {
                target: excubia,
                passerby: passerby,
                attestation_id: 2,
            },
        )
    assert(err == ExcubiaError::RevokedAttestation.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::EASPass {
                target: excubia,
                passerby: passerby,
                attestation_id: 3,
            },
        )
    assert(err == ExcubiaError::UnexpectedSchema.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::EASPass {
                target: excubia,
                passerby: passerby,
                attestation_id: 5,
            },
        )
    assert(err == ExcubiaError::UnexpectedAttester.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::EASPass {
                target: excubia,
                passerby: passerby,
                attestation_id: 1,
            },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: EASExcubiaMsg::HasPassedAttestation { attestation_id: 1 },
        )
    assert(has_passed)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::EASPass {
                target: excubia,
                passerby: passerby,
                attestation_id: 1,
            },
        )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test]
fn test_semaphore_excubia_matches_solidity_behavior() uses (evm: mut Evm) {
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2060)
    let semaphore = evm.create2<MockSemaphore>(value: 0, args: (), salt: 2061)
    let excubia = evm.create2<SemaphoreExcubia>(value: 0, args: (semaphore, 0), salt: 2062)
    let passerby = Address { inner: 0x6001 }

    let trait_value: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: SemaphoreExcubiaMsg::Trait {},
        )
    assert(trait_value == EXCUBIA_TRAIT_SEMAPHORE)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::SemaphoreSetGate { target: excubia, gate: caller },
        )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: SemaphoreExcubiaMsg::SetGate { gate: Address::zero() },
        )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: SemaphoreExcubiaMsg::SetGate { gate: caller },
        )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: SemaphoreExcubiaMsg::Check {
                passerby: passerby,
                merkle_tree_depth: 1,
                merkle_tree_root: 0,
                nullifier: 0,
                message_value: 0,
                scope: 1,
                points: [0, 0, 0, 0, 0, 0, 0, 0],
            },
        )
    assert(err == ExcubiaError::UnexpectedScope.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: SemaphoreExcubiaMsg::Check {
                passerby: passerby,
                merkle_tree_depth: 1,
                merkle_tree_root: 0,
                nullifier: 1,
                message_value: 0,
                scope: 0,
                points: [1, 0, 0, 0, 0, 0, 0, 0],
            },
        )
    assert(err == ExcubiaError::InvalidProof.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: SemaphoreExcubiaMsg::Check {
                passerby: passerby,
                merkle_tree_depth: 1,
                merkle_tree_root: 0,
                nullifier: 0,
                message_value: 0,
                scope: 0,
                points: [0, 0, 0, 0, 0, 0, 0, 0],
            },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: SemaphoreExcubiaMsg::HasPassedNullifier { nullifier: 0 },
        )
    assert(!has_passed)

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: SemaphoreExcubiaMsg::Pass {
                passerby: passerby,
                merkle_tree_depth: 1,
                merkle_tree_root: 0,
                nullifier: 0,
                message_value: 0,
                scope: 0,
                points: [0, 0, 0, 0, 0, 0, 0, 0],
            },
        )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::SemaphorePass {
                target: excubia,
                passerby: passerby,
                merkle_tree_depth: 1,
                merkle_tree_root: 0,
                nullifier: 0,
                message_value: 0,
                scope: 1,
                points: [0, 0, 0, 0, 0, 0, 0, 0],
            },
        )
    assert(err == ExcubiaError::UnexpectedScope.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::SemaphorePass {
                target: excubia,
                passerby: passerby,
                merkle_tree_depth: 1,
                merkle_tree_root: 0,
                nullifier: 1,
                message_value: 0,
                scope: 0,
                points: [1, 0, 0, 0, 0, 0, 0, 0],
            },
        )
    assert(err == ExcubiaError::InvalidProof.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::SemaphorePass {
                target: excubia,
                passerby: passerby,
                merkle_tree_depth: 1,
                merkle_tree_root: 0,
                nullifier: 0,
                message_value: 0,
                scope: 0,
                points: [0, 0, 0, 0, 0, 0, 0, 0],
            },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: SemaphoreExcubiaMsg::HasPassedNullifier { nullifier: 0 },
        )
    assert(has_passed)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::SemaphorePass {
                target: excubia,
                passerby: passerby,
                merkle_tree_depth: 1,
                merkle_tree_root: 0,
                nullifier: 0,
                message_value: 0,
                scope: 0,
                points: [0, 0, 0, 0, 0, 0, 0, 0],
            },
        )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test]
fn test_zkeddsa_event_ticket_pcd_excubia_matches_solidity_behavior()
uses (evm: mut Evm)
{
    let caller = evm.create2<ExcubiaCaller>(value: 0, args: (), salt: 2070)
    let verifier = evm.create2<ZKEdDSAEventTicketPCDVerifier>(value: 0, args: (), salt: 2071)
    let excubia = evm
        .create2<ZKEdDSAEventTicketPCDExcubia>(
            value: 0,
            args: (
                verifier,
                ZKEDDSA_VALID_EVENT_ID,
                ZKEDDSA_VALID_SIGNER_0,
                ZKEDDSA_VALID_SIGNER_1,
            ),
            salt: 2072,
        )
    let invalid_signer_0_excubia = evm
        .create2<ZKEdDSAEventTicketPCDExcubia>(
            value: 0,
            args: (
                verifier,
                ZKEDDSA_VALID_EVENT_ID,
                ZKEDDSA_INVALID_SIGNER_0,
                ZKEDDSA_VALID_SIGNER_1,
            ),
            salt: 2073,
        )
    let invalid_signer_1_excubia = evm
        .create2<ZKEdDSAEventTicketPCDExcubia>(
            value: 0,
            args: (
                verifier,
                ZKEDDSA_VALID_EVENT_ID,
                ZKEDDSA_VALID_SIGNER_0,
                ZKEDDSA_INVALID_SIGNER_1,
            ),
            salt: 2074,
        )
    let invalid_event_id_excubia = evm
        .create2<ZKEdDSAEventTicketPCDExcubia>(
            value: 0,
            args: (
                verifier,
                ZKEDDSA_INVALID_EVENT_ID,
                ZKEDDSA_VALID_SIGNER_0,
                ZKEDDSA_VALID_SIGNER_1,
            ),
            salt: 2075,
        )
    let passerby = Address { inner: 0x627306090abab3a6e1400e9345bc60c78a8bef57 }

    let trait_value: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::Trait {},
        )
    assert(trait_value == EXCUBIA_TRAIT_ZKEDDSA_EVENT_TICKET_PCD)

    let verifier_ok: bool = evm
        .call(
            addr: verifier,
            gas: 5000000,
            value: 0,
            message: ZKEdDSAEventTicketPCDVerifierMsg::VerifyProof {
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(verifier_ok)

    let verifier_ok: bool = evm
        .call(
            addr: verifier,
            gas: 5000000,
            value: 0,
            message: ZKEdDSAEventTicketPCDVerifierMsg::VerifyProof {
                p_a: ZKEDDSA_INVALID_PROOF_A,
                p_b: ZKEDDSA_INVALID_PROOF_B,
                p_c: ZKEDDSA_INVALID_PROOF_C,
                pub_signals: ZKEDDSA_INVALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(!verifier_ok)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 200000,
            value: 0,
            message: ExcubiaCallerMsg::ZKEdDSASetGate { target: excubia, gate: caller },
        )
    assert(err == ExcubiaError::OwnerOnly.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: Address::zero() },
        )
    assert(err == ExcubiaError::ZeroAddress.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: caller },
        )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm
        .call(
            addr: invalid_signer_0_excubia,
            gas: 100000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: caller },
        )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm
        .call(
            addr: invalid_signer_1_excubia,
            gas: 100000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: caller },
        )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm
        .call(
            addr: invalid_event_id_excubia,
            gas: 100000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::SetGate { gate: caller },
        )
    assert(err == ExcubiaError::None.code())

    let err: u256 = evm
        .call(
            addr: invalid_signer_0_excubia,
            gas: 5000000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
                passerby: passerby,
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::InvalidSigners.code())

    let err: u256 = evm
        .call(
            addr: invalid_signer_1_excubia,
            gas: 5000000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
                passerby: passerby,
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::InvalidSigners.code())

    let err: u256 = evm
        .call(
            addr: invalid_event_id_excubia,
            gas: 5000000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
                passerby: passerby,
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::InvalidEventId.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 5000000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
                passerby: passerby,
                p_a: ZKEDDSA_INVALIDWATERMARK_PROOF_A,
                p_b: ZKEDDSA_INVALIDWATERMARK_PROOF_B,
                p_c: ZKEDDSA_INVALIDWATERMARK_PROOF_C,
                pub_signals: ZKEDDSA_INVALIDWATERMARK_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::InvalidWatermark.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 5000000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
                passerby: passerby,
                p_a: ZKEDDSA_INVALID_PROOF_A,
                p_b: ZKEDDSA_INVALID_PROOF_B,
                p_c: ZKEDDSA_INVALID_PROOF_C,
                pub_signals: ZKEDDSA_INVALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::InvalidProof.code())

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 5000000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::Check {
                passerby: passerby,
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::HasPassedZKEdDSAEventTicketPCD {
                ticket_id: ZKEDDSA_VALID_TICKET_ID,
            },
        )
    assert(!has_passed)

    let err: u256 = evm
        .call(
            addr: excubia,
            gas: 5000000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::Pass {
                passerby: passerby,
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::GateOnly.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 5000000,
            value: 0,
            message: ExcubiaCallerMsg::ZKEdDSAPass {
                target: invalid_signer_0_excubia,
                passerby: passerby,
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::InvalidSigners.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 5000000,
            value: 0,
            message: ExcubiaCallerMsg::ZKEdDSAPass {
                target: invalid_signer_1_excubia,
                passerby: passerby,
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::InvalidSigners.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 5000000,
            value: 0,
            message: ExcubiaCallerMsg::ZKEdDSAPass {
                target: invalid_event_id_excubia,
                passerby: passerby,
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::InvalidEventId.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 5000000,
            value: 0,
            message: ExcubiaCallerMsg::ZKEdDSAPass {
                target: excubia,
                passerby: passerby,
                p_a: ZKEDDSA_INVALIDWATERMARK_PROOF_A,
                p_b: ZKEDDSA_INVALIDWATERMARK_PROOF_B,
                p_c: ZKEDDSA_INVALIDWATERMARK_PROOF_C,
                pub_signals: ZKEDDSA_INVALIDWATERMARK_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::InvalidWatermark.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 5000000,
            value: 0,
            message: ExcubiaCallerMsg::ZKEdDSAPass {
                target: excubia,
                passerby: passerby,
                p_a: ZKEDDSA_INVALID_PROOF_A,
                p_b: ZKEDDSA_INVALID_PROOF_B,
                p_c: ZKEDDSA_INVALID_PROOF_C,
                pub_signals: ZKEDDSA_INVALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::InvalidProof.code())

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 5000000,
            value: 0,
            message: ExcubiaCallerMsg::ZKEdDSAPass {
                target: excubia,
                passerby: passerby,
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::None.code())

    let has_passed: bool = evm
        .call(
            addr: excubia,
            gas: 100000,
            value: 0,
            message: ZKEdDSAEventTicketPCDExcubiaMsg::HasPassedZKEdDSAEventTicketPCD {
                ticket_id: ZKEDDSA_VALID_TICKET_ID,
            },
        )
    assert(has_passed)

    let err: u256 = evm
        .call(
            addr: caller,
            gas: 5000000,
            value: 0,
            message: ExcubiaCallerMsg::ZKEdDSAPass {
                target: excubia,
                passerby: passerby,
                p_a: ZKEDDSA_VALID_PROOF_A,
                p_b: ZKEDDSA_VALID_PROOF_B,
                p_c: ZKEDDSA_VALID_PROOF_C,
                pub_signals: ZKEDDSA_VALID_PROOF_PUB_SIGNALS,
            },
        )
    assert(err == ExcubiaError::AlreadyPassed.code())
}

#[test(should_revert)]
fn test_zkeddsa_event_ticket_pcd_excubia_rejects_zero_verifier()
uses (evm: mut Evm)
{
    let _ = evm
        .create2<ZKEdDSAEventTicketPCDExcubia>(
            value: 0,
            args: (
                Address::zero(),
                ZKEDDSA_VALID_EVENT_ID,
                ZKEDDSA_VALID_SIGNER_0,
                ZKEDDSA_VALID_SIGNER_1,
            ),
            salt: 2076,
        )
}
