            merkle_tree_depth,
            merkle_tree_root,
            nullifier,
            message_value,
            scope,
            points,
        } -> u256
        uses (mut call)
        {
            call.call(
                addr: target,
                gas: 200000,
                value: 0,
                message: SemaphoreExcubiaMsg::Pass {
                    passerby: passerby,
                    merkle_tree_depth: merkle_tree_depth,
                    merkle_tree_root: merkle_tree_root,
                    nullifier: nullifier,
                    message_value: message_value,
                    scope: scope,
                    points: points,
