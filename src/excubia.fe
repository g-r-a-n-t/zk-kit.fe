struct SemaphoreExcubiaStore {
    owner: Address,
    gate: Address,
    semaphore: Address,
    group_id: u256,
    passed_nullifiers: StorageMap<u256, bool>,
}

pub contract SemaphoreExcubia uses (ctx: Ctx, call: mut Call, log: mut Log) {
    mut store: SemaphoreExcubiaStore,

    init(semaphore: Address, group_id: u256)
    uses (mut store, ctx, mut call)
    {
        assert(semaphore != Address::zero())
        let group_counter: u256 = call
            .call(
                addr: semaphore,
                gas: 100000,
                value: 0,
                message: MockSemaphoreMsg::GroupCounter {},
            )
        assert(group_counter > group_id)

        store.owner = ctx.caller()
        store.gate = Address::zero()
        store.semaphore = semaphore
        store.group_id = group_id
    }

    recv SemaphoreExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(
                owner: store.owner,
                gate: store.gate,
                caller: ctx.caller(),
                new_gate: gate,
            )
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check {
            passerby,
            merkle_tree_depth,
            merkle_tree_root,
            nullifier,
            message_value,
            scope,
            points,
        } -> u256
        uses (store, mut call)
        {
            let _ = passerby
            let _ = merkle_tree_depth
            let _ = merkle_tree_root
            let _ = message_value
            let _ = points
            semaphore_proof_err(
                semaphore: store.semaphore,
                group_id: store.group_id,
                scope: scope,
                nullifier: nullifier,
            )
                .code()
        }

        Pass {
            passerby,
            merkle_tree_depth,
            merkle_tree_root,
            nullifier,
            message_value,
            scope,
            points,
        } -> u256
        uses (mut store, ctx, mut call, mut log)
        {
            let err = excubia_pass_common_err(
                gate: store.gate,
                caller: ctx.caller(),
                already_passed: store.passed_nullifiers.get(key: nullifier),
            )
            if !err.is_none() {
                return err.code()
            }

            let _ = merkle_tree_depth
            let _ = merkle_tree_root
            let _ = message_value
            let _ = points
            let err = semaphore_proof_err(
                semaphore: store.semaphore,
                group_id: store.group_id,
                scope: scope,
                nullifier: nullifier,
            )
            if !err.is_none() {
                return err.code()
            }

            store.passed_nullifiers.set(key: nullifier, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_SEMAPHORE
        }

        HasPassedNullifier { nullifier } -> bool uses (store) {
            store.passed_nullifiers.get(key: nullifier)
        }
    }
}

pub msg ZKEdDSAEventTicketPCDVerifierMsg {
    #[selector = 0x5d000001]
    VerifyProof {
        p_a: [u256; 2],
        p_b: [[u256; 2]; 2],
        p_c: [u256; 2],
        pub_signals: [u256; 38],
    } -> bool,
}

pub contract ZKEdDSAEventTicketPCDVerifier uses (mem: mut RawMem, call: mut Call) {
    recv ZKEdDSAEventTicketPCDVerifierMsg {
        VerifyProof { p_a, p_b, p_c, pub_signals } -> bool
        uses (mut mem, mut call)
        {
            zkeddsa_verify_proof(p_a: p_a, p_b: p_b, p_c: p_c, pub_signals: pub_signals)
        }
    }
}

fn zkeddsa_external_proof_err(
    verifier: Address,
    valid_event_id: u256,
    valid_signer_0: u256,
    valid_signer_1: u256,
    passerby: Address,
    p_a: [u256; 2],
    p_b: [[u256; 2]; 2],
    p_c: [u256; 2],
    pub_signals: [u256; 38],
) -> ExcubiaError
uses (call: mut Call)
{
    if pub_signals[13] != valid_signer_0 || pub_signals[14] != valid_signer_1 {
        return ExcubiaError::InvalidSigners
    }
    if pub_signals[15] != valid_event_id {
        return ExcubiaError::InvalidEventId
    }
    if pub_signals[37] != passerby.inner {
        return ExcubiaError::InvalidWatermark
    }

    let is_valid: bool = call
        .static(
            addr: verifier,
            gas: 2000000,
            message: ZKEdDSAEventTicketPCDVerifierMsg::VerifyProof {
                p_a: p_a,
                p_b: p_b,
                p_c: p_c,
                pub_signals: pub_signals,
            },
        )
    if !is_valid {
        return ExcubiaError::InvalidProof
    }

    ExcubiaError::None
}

pub msg ZKEdDSAEventTicketPCDExcubiaMsg {
    #[selector = 0x5e000001]
    SetGate { gate: Address } -> u256,
    #[selector = 0x5e000002]
    Check {
        passerby: Address,
        p_a: [u256; 2],
        p_b: [[u256; 2]; 2],
        p_c: [u256; 2],
        pub_signals: [u256; 38],
    } -> u256,
    #[selector = 0x5e000003]
    Pass {
        passerby: Address,
        p_a: [u256; 2],
        p_b: [[u256; 2]; 2],
        p_c: [u256; 2],
        pub_signals: [u256; 38],
    } -> u256,
    #[selector = 0x5e000004]
    Gate -> u256,
    #[selector = 0x5e000005]
    Trait -> u256,
    #[selector = 0x5e000006]
    HasPassedZKEdDSAEventTicketPCD { ticket_id: u256 } -> bool,
}

struct ZKEdDSAEventTicketPCDExcubiaStore {
    owner: Address,
    gate: Address,
    verifier: Address,
    valid_event_id: u256,
    valid_signer_0: u256,
    valid_signer_1: u256,
    passed_ticket_ids: StorageMap<u256, bool>,
}

pub contract ZKEdDSAEventTicketPCDExcubia uses (ctx: Ctx, call: mut Call, log: mut Log) {
    mut store: ZKEdDSAEventTicketPCDExcubiaStore,

    init(verifier: Address, valid_event_id: u256, valid_signer_0: u256, valid_signer_1: u256)
    uses (mut store, ctx)
    {
        assert(verifier != Address::zero())
        store.owner = ctx.caller()
        store.gate = Address::zero()
        store.verifier = verifier
        store.valid_event_id = valid_event_id
        store.valid_signer_0 = valid_signer_0
        store.valid_signer_1 = valid_signer_1
    }

    recv ZKEdDSAEventTicketPCDExcubiaMsg {
        SetGate { gate } -> u256 uses (mut store, ctx, mut log) {
            let err = excubia_set_gate_err(
                owner: store.owner,
                gate: store.gate,
                caller: ctx.caller(),
                new_gate: gate,
            )
            if err.is_none() {
                store.gate = gate
                emit_gate_set(gate: gate)
            }
            err.code()
        }

        Check { passerby, p_a, p_b, p_c, pub_signals } -> u256
        uses (store, mut call)
        {
            zkeddsa_external_proof_err(
                verifier: store.verifier,
                valid_event_id: store.valid_event_id,
                valid_signer_0: store.valid_signer_0,
                valid_signer_1: store.valid_signer_1,
                passerby: passerby,
                p_a: p_a,
                p_b: p_b,
                p_c: p_c,
                pub_signals: pub_signals,
            )
                .code()
        }

        Pass { passerby, p_a, p_b, p_c, pub_signals } -> u256
        uses (mut store, ctx, mut call, mut log)
        {
            let ticket_id = pub_signals[0]
            let err = excubia_pass_common_err(
                gate: store.gate,
                caller: ctx.caller(),
                already_passed: store.passed_ticket_ids.get(key: ticket_id),
            )
            if !err.is_none() {
                return err.code()
            }

            let err = zkeddsa_external_proof_err(
                verifier: store.verifier,
                valid_event_id: store.valid_event_id,
                valid_signer_0: store.valid_signer_0,
                valid_signer_1: store.valid_signer_1,
                passerby: passerby,
                p_a: p_a,
                p_b: p_b,
                p_c: p_c,
                pub_signals: pub_signals,
            )
            if !err.is_none() {
                return err.code()
            }

            store.passed_ticket_ids.set(key: ticket_id, value: true)
            emit_gate_passed(passerby: passerby, gate: store.gate)
            ExcubiaError::None.code()
        }

        Gate -> u256 uses (store) {
            store.gate.inner
        }

        Trait -> u256 {
            EXCUBIA_TRAIT_ZKEDDSA_EVENT_TICKET_PCD
        }

        HasPassedZKEdDSAEventTicketPCD { ticket_id } -> bool
        uses (store)
        {
            store.passed_ticket_ids.get(key: ticket_id)
        }
    }
}

